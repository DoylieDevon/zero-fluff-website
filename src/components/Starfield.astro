---
/**
 * Starfield — twinkling stars, subtle suns with rays, and shooting stars.
 * Full-page fixed canvas behind all content. Respects prefers-reduced-motion.
 */
---

<canvas id="starfield-canvas" aria-hidden="true"></canvas>

<style>
  #starfield-canvas {
    position: fixed;
    inset: 0;
    z-index: -3;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script is:inline data-astro-rerun>
(function initStarfield() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const canvas = document.getElementById('starfield-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  let stars = [];
  let suns = [];
  let shootingStars = [];
  let animId;

  /* ── sizing ─────────────────────────────────────────── */
  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = window.innerWidth;
    H = document.documentElement.scrollHeight;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    createStars();
    createSuns();
  }

  /* ── stars ───────────────────────────────────────────── */
  function createStars() {
    const count = Math.floor((W * H) / 6000);
    stars = [];
    for (let i = 0; i < count; i++) {
      stars.push({
        x: Math.random() * W,
        y: Math.random() * H,
        r: Math.random() * 1.4 + 0.3,
        baseAlpha: Math.random() * 0.5 + 0.15,
        phase: Math.random() * Math.PI * 2,
        speed: Math.random() * 1.5 + 0.5,
        // Some stars twinkle more dramatically
        twinkleAmp: Math.random() < 0.15 ? 0.8 : Math.random() * 0.4 + 0.1,
        color: randomStarColor(),
      });
    }
  }

  function randomStarColor() {
    const roll = Math.random();
    if (roll < 0.6) return { r: 255, g: 255, b: 255 };         // white
    if (roll < 0.75) return { r: 200, g: 220, b: 255 };        // blue-white
    if (roll < 0.85) return { r: 255, g: 230, b: 200 };        // warm white
    if (roll < 0.92) return { r: 255, g: 180, b: 180 };        // reddish (brand)
    return { r: 180, g: 240, b: 255 };                          // cyan-ish (brand)
  }

  /* ── suns ────────────────────────────────────────────── */
  function createSuns() {
    // 2-4 suns scattered down the page
    const count = Math.floor(Math.random() * 3) + 2;
    suns = [];
    for (let i = 0; i < count; i++) {
      suns.push({
        x: Math.random() * W * 0.8 + W * 0.1,
        y: (H / (count + 1)) * (i + 1) + (Math.random() - 0.5) * 200,
        baseR: Math.random() * 2 + 1.5,
        rayLength: Math.random() * 30 + 20,
        numRays: Math.floor(Math.random() * 4) + 6,
        phase: Math.random() * Math.PI * 2,
        rotSpeed: (Math.random() - 0.5) * 0.3,
        pulseSpeed: Math.random() * 0.8 + 0.3,
        color: Math.random() < 0.5
          ? { r: 255, g: 200, b: 150 }   // warm gold
          : { r: 200, g: 230, b: 255 },  // cool blue
      });
    }
  }

  /* ── shooting stars ─────────────────────────────────── */
  function maybeSpawnShootingStar() {
    if (shootingStars.length >= 2) return;
    if (Math.random() > 0.003) return; // ~every 5-6 seconds on average

    const startX = Math.random() * W * 0.8 + W * 0.1;
    const startY = Math.random() * H * 0.6;
    const angle = Math.random() * 0.6 + 0.3; // 17° - 52° downward
    const speed = Math.random() * 8 + 6;
    const life = Math.random() * 40 + 30;

    shootingStars.push({
      x: startX,
      y: startY,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      life: life,
      maxLife: life,
      length: Math.random() * 60 + 40,
    });
  }

  /* ── draw loop ──────────────────────────────────────── */
  let t = 0;
  function draw() {
    t += 0.016; // ~60fps timestep
    ctx.clearRect(0, 0, W, H);

    // Offset for scroll — canvas is fixed but sized to doc height
    const scrollY = window.scrollY || 0;
    const viewTop = scrollY;
    const viewBottom = scrollY + window.innerHeight;

    /* stars */
    for (let i = 0; i < stars.length; i++) {
      const s = stars[i];
      // Only draw stars in viewport + margin
      if (s.y < viewTop - 20 || s.y > viewBottom + 20) continue;

      const flicker = Math.sin(t * s.speed + s.phase) * s.twinkleAmp;
      const alpha = Math.max(0, Math.min(1, s.baseAlpha + flicker));

      ctx.beginPath();
      ctx.arc(s.x, s.y - scrollY, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${s.color.r},${s.color.g},${s.color.b},${alpha})`;
      ctx.fill();

      // Bright stars get a subtle glow
      if (alpha > 0.6 && s.r > 1) {
        ctx.beginPath();
        ctx.arc(s.x, s.y - scrollY, s.r * 3, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${s.color.r},${s.color.g},${s.color.b},${alpha * 0.12})`;
        ctx.fill();
      }
    }

    /* suns */
    for (let i = 0; i < suns.length; i++) {
      const sun = suns[i];
      if (sun.y < viewTop - 80 || sun.y > viewBottom + 80) continue;

      const drawY = sun.y - scrollY;
      const pulse = 0.6 + Math.sin(t * sun.pulseSpeed + sun.phase) * 0.4;
      const rot = t * sun.rotSpeed + sun.phase;

      // Core glow
      const grad = ctx.createRadialGradient(sun.x, drawY, 0, sun.x, drawY, sun.baseR * 8);
      grad.addColorStop(0, `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.25 * pulse})`);
      grad.addColorStop(0.4, `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.08 * pulse})`);
      grad.addColorStop(1, 'transparent');
      ctx.beginPath();
      ctx.arc(sun.x, drawY, sun.baseR * 8, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      // Core dot
      ctx.beginPath();
      ctx.arc(sun.x, drawY, sun.baseR, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.7 * pulse})`;
      ctx.fill();

      // Rays
      ctx.save();
      ctx.translate(sun.x, drawY);
      ctx.rotate(rot);
      for (let r = 0; r < sun.numRays; r++) {
        const angle = (Math.PI * 2 / sun.numRays) * r;
        const rayLen = sun.rayLength * pulse * (0.7 + Math.sin(t * 2 + r) * 0.3);
        ctx.beginPath();
        ctx.moveTo(0, 0);
        const ex = Math.cos(angle) * rayLen;
        const ey = Math.sin(angle) * rayLen;
        ctx.lineTo(ex, ey);
        ctx.strokeStyle = `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.08 * pulse})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }
      ctx.restore();
    }

    /* shooting stars */
    maybeSpawnShootingStar();
    for (let i = shootingStars.length - 1; i >= 0; i--) {
      const ss = shootingStars[i];
      ss.x += ss.vx;
      ss.y += ss.vy;
      ss.life--;

      if (ss.life <= 0 || ss.x > W + 50 || ss.y > H + 50) {
        shootingStars.splice(i, 1);
        continue;
      }

      const drawY = ss.y - scrollY;
      // Only draw if in viewport
      if (drawY < -100 || drawY > window.innerHeight + 100) continue;

      const progress = 1 - (ss.life / ss.maxLife);
      const alpha = progress < 0.3
        ? progress / 0.3            // fade in
        : (1 - progress) / 0.7;    // fade out

      const tailX = ss.x - ss.vx * (ss.length / Math.sqrt(ss.vx * ss.vx + ss.vy * ss.vy));
      const tailY = drawY - ss.vy * (ss.length / Math.sqrt(ss.vx * ss.vx + ss.vy * ss.vy));

      const grad = ctx.createLinearGradient(tailX, tailY, ss.x, drawY);
      grad.addColorStop(0, `rgba(255,255,255,0)`);
      grad.addColorStop(0.6, `rgba(255,255,255,${alpha * 0.3})`);
      grad.addColorStop(1, `rgba(255,255,255,${alpha * 0.8})`);

      ctx.beginPath();
      ctx.moveTo(tailX, tailY);
      ctx.lineTo(ss.x, drawY);
      ctx.strokeStyle = grad;
      ctx.lineWidth = 1.5;
      ctx.lineCap = 'round';
      ctx.stroke();

      // Bright head
      ctx.beginPath();
      ctx.arc(ss.x, drawY, 1.5, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${alpha * 0.9})`;
      ctx.fill();
    }

    animId = requestAnimationFrame(draw);
  }

  /* ── init ───────────────────────────────────────────── */
  let resizeTimer;
  function handleResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(resize, 200);
  }

  window.addEventListener('resize', handleResize);
  resize();
  draw();

  // Cleanup on page transition
  document.addEventListener('astro:before-swap', function cleanup() {
    cancelAnimationFrame(animId);
    window.removeEventListener('resize', handleResize);
    document.removeEventListener('astro:before-swap', cleanup);
  });
})();
</script>
