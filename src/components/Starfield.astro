---
/**
 * Starfield — twinkling stars, subtle suns with rays, and shooting stars with trails.
 * Full-page fixed canvas behind all content. Respects prefers-reduced-motion.
 */
---

<canvas id="starfield-canvas" aria-hidden="true"></canvas>

<style>
  #starfield-canvas {
    position: fixed;
    inset: 0;
    z-index: -3;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script is:inline data-astro-rerun>
(function initStarfield() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const canvas = document.getElementById('starfield-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, docH;
  let stars = [];
  let suns = [];
  let shootingStars = [];
  let animId;

  /* ── sizing ─────────────────────────────────────────── */
  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    W = window.innerWidth;
    H = window.innerHeight;
    docH = Math.max(document.documentElement.scrollHeight, H);
    // Canvas only needs to be viewport-sized (it's position:fixed)
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    createStars();
    createSuns();
  }

  /* ── stars ───────────────────────────────────────────── */
  function createStars() {
    // Use full document height for star distribution
    const count = Math.floor((W * docH) / 4500);
    stars = [];
    for (let i = 0; i < count; i++) {
      const sizeRoll = Math.random();
      let r;
      if (sizeRoll < 0.45) r = Math.random() * 0.6 + 0.2;       // tiny pinpricks
      else if (sizeRoll < 0.75) r = Math.random() * 0.8 + 0.6;   // small
      else if (sizeRoll < 0.92) r = Math.random() * 1.0 + 1.0;   // medium
      else r = Math.random() * 1.5 + 1.8;                         // big bright ones

      // More stars twinkle dramatically
      const twinkleRoll = Math.random();
      let twinkleAmp, twinkleSpeed;
      if (twinkleRoll < 0.2) {
        // Rapid sparklers — very noticeable twinkle
        twinkleAmp = Math.random() * 0.5 + 0.6;
        twinkleSpeed = Math.random() * 4 + 3;
      } else if (twinkleRoll < 0.5) {
        // Moderate twinklers
        twinkleAmp = Math.random() * 0.4 + 0.3;
        twinkleSpeed = Math.random() * 2.5 + 1.5;
      } else {
        // Gentle shimmer
        twinkleAmp = Math.random() * 0.25 + 0.05;
        twinkleSpeed = Math.random() * 1.5 + 0.5;
      }

      stars.push({
        x: Math.random() * W,
        y: Math.random() * docH,
        r: r,
        baseAlpha: Math.random() * 0.5 + 0.2,
        phase: Math.random() * Math.PI * 2,
        // Second sine wave for more organic twinkle
        phase2: Math.random() * Math.PI * 2,
        speed: twinkleSpeed,
        speed2: twinkleSpeed * (Math.random() * 0.7 + 0.3),
        twinkleAmp: twinkleAmp,
        twinkleAmp2: twinkleAmp * (Math.random() * 0.5 + 0.2),
        color: randomStarColor(),
      });
    }
  }

  function randomStarColor() {
    const roll = Math.random();
    if (roll < 0.35) return { r: 255, g: 255, b: 255 };          // pure white
    if (roll < 0.48) return { r: 220, g: 235, b: 255 };          // ice blue
    if (roll < 0.58) return { r: 180, g: 200, b: 255 };          // deeper blue
    if (roll < 0.66) return { r: 255, g: 245, b: 220 };          // warm cream
    if (roll < 0.73) return { r: 255, g: 220, b: 180 };          // pale gold
    if (roll < 0.79) return { r: 255, g: 200, b: 200 };          // soft pink
    if (roll < 0.84) return { r: 255, g: 170, b: 160 };          // salmon (brand red hint)
    if (roll < 0.89) return { r: 170, g: 240, b: 255 };          // cyan (brand)
    if (roll < 0.93) return { r: 200, g: 255, b: 220 };          // pale green
    if (roll < 0.96) return { r: 240, g: 200, b: 255 };          // soft lavender
    return { r: 255, g: 255, b: 200 };                            // pale yellow
  }

  /* ── suns ────────────────────────────────────────────── */
  function createSuns() {
    const count = Math.floor(Math.random() * 3) + 2;
    suns = [];
    for (let i = 0; i < count; i++) {
      suns.push({
        x: Math.random() * W * 0.8 + W * 0.1,
        y: (docH / (count + 1)) * (i + 1) + (Math.random() - 0.5) * 200,
        baseR: Math.random() * 2 + 1.5,
        rayLength: Math.random() * 30 + 20,
        numRays: Math.floor(Math.random() * 4) + 6,
        phase: Math.random() * Math.PI * 2,
        rotSpeed: (Math.random() - 0.5) * 0.3,
        pulseSpeed: Math.random() * 0.8 + 0.3,
        color: Math.random() < 0.5
          ? { r: 255, g: 200, b: 150 }
          : { r: 200, g: 230, b: 255 },
      });
    }
  }

  /* ── shooting stars ─────────────────────────────────── */
  function maybeSpawnShootingStar() {
    if (shootingStars.length >= 2) return;
    if (Math.random() > 0.003) return;

    const scrollY = window.scrollY || 0;
    // Spawn shooting stars near current viewport
    const startX = Math.random() * W * 0.8 + W * 0.1;
    const startY = scrollY + Math.random() * H * 0.6;
    const angle = Math.random() * 0.6 + 0.3;
    const speed = Math.random() * 8 + 6;
    const life = Math.random() * 50 + 35;

    shootingStars.push({
      x: startX,
      y: startY,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      life: life,
      maxLife: life,
      trail: [], // position history for fading trail
    });
  }

  /* ── draw loop ──────────────────────────────────────── */
  let t = 0;
  function draw() {
    t += 0.016;
    ctx.clearRect(0, 0, W, H);

    const scrollY = window.scrollY || 0;
    const viewTop = scrollY;
    const viewBottom = scrollY + H;

    /* stars */
    for (let i = 0; i < stars.length; i++) {
      const s = stars[i];
      if (s.y < viewTop - 20 || s.y > viewBottom + 20) continue;

      // Dual-sine twinkle for more organic sparkle
      const flicker1 = Math.sin(t * s.speed + s.phase) * s.twinkleAmp;
      const flicker2 = Math.sin(t * s.speed2 + s.phase2) * s.twinkleAmp2;
      const alpha = Math.max(0, Math.min(1, s.baseAlpha + flicker1 + flicker2));

      const drawY = s.y - scrollY;

      ctx.beginPath();
      ctx.arc(s.x, drawY, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${s.color.r},${s.color.g},${s.color.b},${alpha})`;
      ctx.fill();

      // Bigger/brighter stars get a glow halo
      if (alpha > 0.55 && s.r > 0.8) {
        ctx.beginPath();
        ctx.arc(s.x, drawY, s.r * 3.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${s.color.r},${s.color.g},${s.color.b},${alpha * 0.1})`;
        ctx.fill();
      }

      // The biggest stars get a cross-sparkle when bright
      if (alpha > 0.7 && s.r > 1.5) {
        const sparkLen = s.r * 5 * alpha;
        ctx.strokeStyle = `rgba(${s.color.r},${s.color.g},${s.color.b},${alpha * 0.15})`;
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        ctx.moveTo(s.x - sparkLen, drawY);
        ctx.lineTo(s.x + sparkLen, drawY);
        ctx.moveTo(s.x, drawY - sparkLen);
        ctx.lineTo(s.x, drawY + sparkLen);
        ctx.stroke();
      }
    }

    /* suns */
    for (let i = 0; i < suns.length; i++) {
      const sun = suns[i];
      if (sun.y < viewTop - 80 || sun.y > viewBottom + 80) continue;

      const drawY = sun.y - scrollY;
      const pulse = 0.6 + Math.sin(t * sun.pulseSpeed + sun.phase) * 0.4;
      const rot = t * sun.rotSpeed + sun.phase;

      const grad = ctx.createRadialGradient(sun.x, drawY, 0, sun.x, drawY, sun.baseR * 8);
      grad.addColorStop(0, `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.25 * pulse})`);
      grad.addColorStop(0.4, `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.08 * pulse})`);
      grad.addColorStop(1, 'transparent');
      ctx.beginPath();
      ctx.arc(sun.x, drawY, sun.baseR * 8, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      ctx.beginPath();
      ctx.arc(sun.x, drawY, sun.baseR, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.7 * pulse})`;
      ctx.fill();

      ctx.save();
      ctx.translate(sun.x, drawY);
      ctx.rotate(rot);
      for (let r = 0; r < sun.numRays; r++) {
        const angle = (Math.PI * 2 / sun.numRays) * r;
        const rayLen = sun.rayLength * pulse * (0.7 + Math.sin(t * 2 + r) * 0.3);
        ctx.beginPath();
        ctx.moveTo(0, 0);
        ctx.lineTo(Math.cos(angle) * rayLen, Math.sin(angle) * rayLen);
        ctx.strokeStyle = `rgba(${sun.color.r},${sun.color.g},${sun.color.b},${0.08 * pulse})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }
      ctx.restore();
    }

    /* shooting stars with fading trail */
    maybeSpawnShootingStar();
    for (let i = shootingStars.length - 1; i >= 0; i--) {
      const ss = shootingStars[i];
      ss.x += ss.vx;
      ss.y += ss.vy;
      ss.life--;

      // Store trail position
      ss.trail.push({ x: ss.x, y: ss.y });
      // Keep trail max ~40 points
      if (ss.trail.length > 40) ss.trail.shift();

      if (ss.life <= 0 || ss.x > W + 50 || ss.y > docH + 50) {
        // Let trail fade out after head dies
        if (ss.trail.length > 0 && ss.life > -30) {
          ss.life--;
          if (ss.life <= 0) ss.trail.shift();
        }
        if (ss.trail.length <= 1 || ss.life <= -30) {
          shootingStars.splice(i, 1);
          continue;
        }
      }

      const headDrawY = ss.y - scrollY;
      if (headDrawY < -150 || headDrawY > H + 150) continue;

      const progress = 1 - Math.max(0, ss.life) / ss.maxLife;
      const headAlpha = ss.life > 0
        ? (progress < 0.2 ? progress / 0.2 : (1 - progress) / 0.8)
        : 0;

      // Draw trail as series of fading segments
      if (ss.trail.length > 1) {
        for (let p = 1; p < ss.trail.length; p++) {
          const segAlpha = (p / ss.trail.length) * (ss.life > 0 ? 0.6 : 0.6 * (1 + ss.life / 30));
          const prev = ss.trail[p - 1];
          const curr = ss.trail[p];
          const py = prev.y - scrollY;
          const cy = curr.y - scrollY;

          // Trail gets thinner toward the tail
          const thickness = (p / ss.trail.length) * 2;

          ctx.beginPath();
          ctx.moveTo(prev.x, py);
          ctx.lineTo(curr.x, cy);
          ctx.strokeStyle = `rgba(255,255,255,${Math.max(0, segAlpha * 0.5)})`;
          ctx.lineWidth = thickness;
          ctx.lineCap = 'round';
          ctx.stroke();
        }

        // Warm glow along the trail mid-section
        const midIdx = Math.floor(ss.trail.length * 0.7);
        if (midIdx < ss.trail.length) {
          const mp = ss.trail[midIdx];
          const glowAlpha = ss.life > 0 ? 0.08 : 0.08 * Math.max(0, (1 + ss.life / 30));
          ctx.beginPath();
          ctx.arc(mp.x, mp.y - scrollY, 6, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255,220,180,${glowAlpha})`;
          ctx.fill();
        }
      }

      // Bright head with glow
      if (ss.life > 0 && headAlpha > 0) {
        // Outer glow
        ctx.beginPath();
        ctx.arc(ss.x, headDrawY, 4, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,240,220,${headAlpha * 0.2})`;
        ctx.fill();

        // Core
        ctx.beginPath();
        ctx.arc(ss.x, headDrawY, 2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${headAlpha * 0.95})`;
        ctx.fill();
      }
    }

    animId = requestAnimationFrame(draw);
  }

  /* ── init ───────────────────────────────────────────── */
  let resizeTimer;
  function handleResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(resize, 200);
  }

  window.addEventListener('resize', handleResize);
  resize();
  draw();

  document.addEventListener('astro:before-swap', function cleanup() {
    cancelAnimationFrame(animId);
    window.removeEventListener('resize', handleResize);
    document.removeEventListener('astro:before-swap', cleanup);
  });
})();
</script>
