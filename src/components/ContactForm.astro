<form id="contact-form" class="contact-form" novalidate>
  <!-- Hidden name field populated from firstName + lastName by JS -->
  <input type="hidden" id="name" name="name" />

  <!-- First + Last name row -->
  <div class="form-row">
    <div class="form-group">
      <label for="firstName">First Name</label>
      <input type="text" id="firstName" name="firstName" required autocomplete="given-name" placeholder="Jane" />
      <span class="field-error" id="firstName-error" aria-live="polite"></span>
    </div>
    <div class="form-group">
      <label for="lastName">Last Name</label>
      <input type="text" id="lastName" name="lastName" autocomplete="family-name" placeholder="Smith" />
      <span class="field-error" id="lastName-error" aria-live="polite"></span>
    </div>
  </div>

  <div class="form-group">
    <label for="email">Email Address</label>
    <input type="email" id="email" name="email" required autocomplete="email" placeholder="jane@yourbusiness.com" />
    <span class="field-error" id="email-error" aria-live="polite"></span>
  </div>

  <div class="form-group">
    <label for="businessName">Business Name</label>
    <input type="text" id="businessName" name="businessName" autocomplete="organization" placeholder="Your Business Ltd" />
  </div>

  <div class="form-group">
    <label for="message">Message</label>
    <textarea id="message" name="message" rows="6" required placeholder="Tell me about your business and what you're hoping to achieve..."></textarea>
    <span class="field-error" id="message-error" aria-live="polite"></span>
  </div>

  <!-- Honeypot -->
  <div class="visually-hidden" aria-hidden="true">
    <label for="website">Website</label>
    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <div>
    <button type="submit" class="btn-submit">Send Message →</button>
  </div>

  <div id="form-status" aria-live="polite"></div>
</form>

<style>
  .contact-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 13px;
    font-weight: 700;
    color: #000;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .form-group input,
  .form-group textarea {
    padding: 14px 16px;
    border: 1.5px solid #E4E4E7;
    border-radius: 0;
    font-size: 16px;
    background: white;
    color: #000;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #A1A1AA;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #FF3B30;
    box-shadow: 0 0 0 3px rgba(255, 59, 48, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 140px;
  }

  .field-error {
    font-size: 13px;
    color: #dc2626;
    min-height: 1.25em;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .btn-submit {
    display: inline-block;
    background: #FF3B30;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    padding: 16px 36px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: opacity 0.15s ease;
  }

  .btn-submit:hover {
    opacity: 0.85;
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  #form-status {
    font-size: 15px;
    padding: 14px 16px;
    border-radius: 0;
  }

  #form-status:empty {
    display: none;
  }

  #form-status.success {
    background: #f0fdf4;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  #form-status.error {
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { actions, isInputError } from 'astro:actions';

  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    // Prevent double-binding
    if (form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const statusEl = document.getElementById('form-status')!;
    const fields = ['name', 'email', 'message'] as const;

    function clearErrors() {
      fields.forEach((field) => {
        const errorEl = document.getElementById(`${field}-error`);
        if (errorEl) errorEl.textContent = '';
      });
      const firstNameError = document.getElementById('firstName-error');
      if (firstNameError) firstNameError.textContent = '';
      statusEl.textContent = '';
      statusEl.className = '';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors();

      // Combine first + last name into the hidden name field
      const firstNameEl = form.querySelector('#firstName') as HTMLInputElement;
      const lastNameEl = form.querySelector('#lastName') as HTMLInputElement;
      const nameEl = form.querySelector('#name') as HTMLInputElement;
      const firstName = firstNameEl?.value?.trim() || '';
      const lastName = lastNameEl?.value?.trim() || '';

      if (!firstName) {
        const errorEl = document.getElementById('firstName-error');
        if (errorEl) errorEl.textContent = 'First name is required';
        firstNameEl?.focus();
        return;
      }

      nameEl.value = lastName ? `${firstName} ${lastName}` : firstName;

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      const formData = new FormData(form);
      const { data, error } = await actions.contact(formData);

      if (error) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;

        if (isInputError(error)) {
          // Show field-level validation errors
          for (const field of fields) {
            const fieldErrors = error.fields[field];
            if (fieldErrors && fieldErrors.length > 0) {
              const errorEl = document.getElementById(`${field}-error`);
              if (errorEl) errorEl.textContent = fieldErrors[0];
            }
          }
        } else {
          statusEl.textContent = 'Something went wrong. Please try again or email me directly.';
          statusEl.className = 'error';
        }
        return;
      }

      // Success
      form.reset();
      nameEl.value = '';
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
      statusEl.textContent = "Thanks! Your message has been sent. I'll be in touch soon.";
      statusEl.className = 'success';
    });
  }

  // Support both initial load and ClientRouter navigations
  document.addEventListener('DOMContentLoaded', initContactForm);
  document.addEventListener('astro:page-load', initContactForm);
</script>
