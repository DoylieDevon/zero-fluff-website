---
interface Props {
  id: string;
  title: string;
  client: string;
  result: string;
  subtitle?: string;
  image?: string;
  tech?: { name: string; category: string }[];
}
const { id, title, client, result, subtitle, image, tech } = Astro.props;
---

<a href={`/case-studies/${id}`} class="cs-card">
  <div class="cs-card-image-wrap">
    {image
      ? <img src={image} alt={`${client} — ${title}`} class="cs-card-image" loading="lazy" />
      : <div class="cs-card-image-placeholder" aria-hidden="true"></div>
    }
    <div class="cs-card-overlay" aria-hidden="true"></div>
    <span class="cs-card-result">{result}</span>
  </div>

  <div class="cs-card-body">
    <div class="cs-card-meta">
      <span class="cs-card-client">{client}</span>
    </div>
    <h3 class="cs-card-title">{title}</h3>
    {subtitle && <p class="cs-card-subtitle">{subtitle}</p>}

    {tech && tech.length > 0 && (
      <div class="cs-card-tech" aria-hidden="true">
        {tech.slice(0, 4).map((t) => (
          <span class="cs-card-tech-pill">{t.name}</span>
        ))}
        {tech.length > 4 && <span class="cs-card-tech-more">+{tech.length - 4}</span>}
      </div>
    )}

    <span class="cs-card-arrow" aria-hidden="true">View case study →</span>
  </div>
</a>

<style>
  .cs-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease;
    position: relative;
  }

  .cs-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
  }

  .cs-card-image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-elevated);
  }

  .cs-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.7) brightness(0.8);
    transition: filter 0.4s ease, transform 0.4s ease;
  }

  .cs-card:hover .cs-card-image {
    filter: saturate(0.9) brightness(0.9);
    transform: scale(1.03);
  }

  .cs-card-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a0533, #0a1628);
  }

  .cs-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.8) 0%, transparent 60%);
    pointer-events: none;
  }

  .cs-card-result {
    position: absolute;
    bottom: 14px;
    left: 16px;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -0.5px;
    text-shadow: 0 0 20px rgba(255,59,48,0.5);
    z-index: 1;
  }

  .cs-card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .cs-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cs-card-client {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .cs-card-title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.5px;
    line-height: 1.15;
  }

  .cs-card-subtitle {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .cs-card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .cs-card-tech-pill {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 4px 10px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    letter-spacing: 0.5px;
    transition: border-color 0.2s, color 0.2s;
  }

  .cs-card:hover .cs-card-tech-pill {
    border-color: rgba(255,59,48,0.3);
    color: var(--color-text-secondary);
  }

  .cs-card-tech-more {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 4px 10px;
  }

  .cs-card-arrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
    padding-top: 8px;
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    display: block;
  }

  .cs-card:hover .cs-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
