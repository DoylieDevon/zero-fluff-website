---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
export const prerender = true;

const studies = await getCollection('case-studies');
studies.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const topStudies = studies.slice(0, 3);
---

<BaseLayout
  title="AI Consultancy South West UK — Zero Fluff"
  description="AI consultancy for the South West UK. Zero Fluff helps small businesses across Devon, Cornwall, Somerset, Dorset and Bristol save time and money with practical AI and automation."
>

  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-content">
      <span class="hero-eyebrow">AI CONSULTANCY · SOUTH WEST UK</span>
      <h1>AI consultancy for the<br>South West</h1>
      <p>Practical AI and automation for small businesses across the South West — Devon, Cornwall, Somerset, Dorset and Bristol. Plain English advice and hands-on builds from a consultancy based right here in the region.</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-red">Book a free AI chat →</a>
        <a href="/services" class="btn-ghost">See our services</a>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="prose-section">
    <div class="prose-inner">
      <p class="lead">Zero Fluff is an AI and automation consultancy for the South West of England. We're based in Totnes, Devon, and work with small businesses right across the region — helping owners cut the admin, free up their time, and use AI in ways that actually move the needle.</p>
      <p>There's a lot of noise around AI right now, and most small businesses in the South West don't have time to wade through it. You don't need a strategy deck full of buzzwords. You need someone who'll look at how your business actually runs, spot the jobs that AI can take off your plate, and then go and build them. That's what we do.</p>
      <p>The South West is largely a region of independent and owner-run businesses, and the big-city consultancies rarely understand that. We do. Whether you're a hospitality business in Cornwall, a manufacturer in Somerset, a professional firm in Bristol, or a holiday business in Dorset, the advice is the same: honest, practical, and focused on results you can measure.</p>
    </div>
  </section>

  <!-- AREAS SERVED -->
  <section class="cards-section">
    <div class="cards-inner">
      <span class="section-label">WHERE WE WORK</span>
      <h2>Serving businesses across the South West</h2>
      <div class="feature-grid">
        <div class="feature-card">
          <h3>Devon</h3>
          <p>Our home patch. Totnes, Exeter, Plymouth, Torbay and beyond — see our <a href="/ai-automation-devon" class="inline-link">AI automation for Devon businesses</a>.</p>
        </div>
        <div class="feature-card">
          <h3>Cornwall</h3>
          <p>From Truro to Penzance — automation and AI for tourism, hospitality, trades and independents.</p>
        </div>
        <div class="feature-card">
          <h3>Somerset</h3>
          <p>Taunton, Bridgwater, Yeovil and the wider county — practical AI for service and product businesses.</p>
        </div>
        <div class="feature-card">
          <h3>Dorset</h3>
          <p>Bournemouth, Poole, Dorchester and the coast — freeing up time for owner-run businesses.</p>
        </div>
        <div class="feature-card">
          <h3>Bristol</h3>
          <p>The region's biggest hub — AI integration and custom software for growing businesses and agencies.</p>
        </div>
        <div class="feature-card">
          <h3>Anywhere in between</h3>
          <p>Most work happens remotely, with in-person sessions when they help. Distance is rarely a barrier.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section class="prose-section alt">
    <div class="prose-inner">
      <span class="section-label">HOW IT WORKS</span>
      <h2>Local consultancy, real delivery</h2>
      <p>Most clients start with an <a href="/services" class="inline-link">AI Quick Start</a> — a focused two-hour review that turns "we should probably do something with AI" into a clear, costed plan. From there we build the <a href="/services" class="inline-link">automations</a> for you, develop <a href="/services/custom-ai-software-development" class="inline-link">custom AI software</a> where it's needed, or provide <a href="/services" class="inline-link">ongoing support</a> to keep everything running and improving.</p>
      <p>Being based in the South West means we can meet face to face when it counts, but day to day, most of the work happens remotely — so you get the same hands-on service whether you're ten minutes away or the other side of the region.</p>
    </div>
  </section>

  <!-- CASE STUDIES -->
  <section class="cards-section">
    <div class="cards-inner">
      <span class="section-label">PROOF, NOT PROMISES</span>
      <h2>Recent work</h2>
      <div class="study-grid">
        {topStudies.map((study) => (
          <a href={`/case-studies/${study.id}`} class="study-card">
            <span class="study-client">{study.data.client}</span>
            <h3>{study.data.title}</h3>
            <span class="study-result">{study.data.result}</span>
          </a>
        ))}
      </div>
      <a href="/case-studies" class="all-link">See all case studies →</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="services-cta">
    <div class="services-cta-content">
      <h2>Based in the South West?</h2>
      <p>Book a free 20-minute AI chat. No sales pitch, no jargon — just a straight conversation about where AI and automation could help your business.</p>
      <a href="/contact" class="btn-red cta-btn-lg">Book a free AI chat →</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    min-height: 520px;
    background: var(--color-surface);
    position: relative;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    padding: 0 80px;
    max-width: 860px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    color: #FF3B30;
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .page-hero-content h1 {
    font-size: 56px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -1.5px;
    line-height: 1.05;
  }
  .page-hero-content > p {
    font-size: 20px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 8px;
  }
  .btn-red {
    display: inline-block;
    background: #FF3B30;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-red:hover { opacity: 0.85; color: #fff; }
  .btn-ghost {
    display: inline-block;
    background: transparent;
    color: var(--color-text);
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    text-decoration: none;
    border: 2px solid rgba(255, 255, 255, 0.3);
    transition: border-color 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255, 255, 255, 0.6); color: #fff; }

  /* PROSE */
  .prose-section {
    background: var(--color-bg);
    padding: 80px;
  }
  .prose-section.alt { background: var(--color-surface); }
  .prose-inner {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .prose-inner .lead {
    font-size: 22px;
    color: var(--color-text);
    line-height: 1.55;
    font-weight: 500;
  }
  .prose-inner p {
    font-size: 18px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .prose-inner h2 {
    font-size: 32px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }
  .section-label {
    font-size: 12px;
    font-weight: 700;
    color: #FF3B30;
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .inline-link {
    color: #FF3B30;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 59, 48, 0.4);
    transition: border-color 0.15s;
  }
  .inline-link:hover { border-bottom-color: #FF3B30; }

  /* CARDS */
  .cards-section {
    background: var(--color-bg);
    padding: 80px;
    border-top: 1px solid var(--color-border);
  }
  .cards-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .cards-inner > h2 {
    font-size: 36px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.5px;
    margin-bottom: 24px;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .feature-card {
    padding: 32px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .feature-card h3 {
    font-size: 21px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.3px;
  }
  .feature-card p {
    font-size: 16px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* STUDY CARDS */
  .study-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .study-card {
    padding: 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .study-card:hover { border-color: #FF3B30; transform: translateY(-2px); }
  .study-client {
    font-size: 10px;
    font-weight: 700;
    color: #FF3B30;
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }
  .study-card h3 {
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.3px;
    line-height: 1.2;
    flex: 1;
  }
  .study-result {
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text-secondary);
  }
  .all-link {
    margin-top: 24px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 2px solid #FF3B30;
    padding-bottom: 2px;
    align-self: flex-start;
    transition: color 0.15s;
  }
  .all-link:hover { color: #FF3B30; }

  /* CTA */
  .services-cta {
    min-height: 300px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .services-cta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
    padding: 60px 80px;
    max-width: 720px;
  }
  .services-cta-content h2 {
    font-size: 48px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -1px;
  }
  .services-cta-content p {
    font-size: 18px;
    color: #ccc;
    line-height: 1.6;
  }
  .cta-btn-lg { font-size: 18px; padding: 20px 48px; }

  @media (max-width: 768px) {
    .page-hero-content { padding: 0 24px; }
    .page-hero-content h1 { font-size: 38px; }
    .prose-section { padding: 60px 24px; }
    .prose-inner .lead { font-size: 19px; }
    .cards-section { padding: 60px 24px; }
    .feature-grid { grid-template-columns: 1fr; }
    .study-grid { grid-template-columns: 1fr; }
    .services-cta-content { padding: 40px 24px; }
    .services-cta-content h2 { font-size: 36px; }
  }
</style>
