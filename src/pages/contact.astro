---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact - Zero Fluff"
  description="Get in touch about AI implementation for your business. No sales pitch, just a straight conversation."
>

  <!-- HERO -->
  <section class="contact-hero">
    <div class="contact-hero-content">
      <h1>Let's have a<br>conversation</h1>
      <p>No sales pitch. No jargon. Just a straight talk about what AI can do for your business.</p>
    </div>
  </section>

  <!-- FORM + DETAILS -->
  <section class="contact-body">
    <div class="contact-body-inner">

      <!-- LEFT: Form -->
      <div class="contact-form-col">
        <span class="section-label">DROP US A LINE</span>
        <h2>Send us a message</h2>
        <ContactForm />
      </div>

      <!-- RIGHT: Info card -->
      <div class="contact-info-card">
        <h3>Book a free 20-min AI chat</h3>
        <p class="card-desc">Not sure where to start with AI? Let's have a no-obligation conversation about your business. I'll give you honest, practical advice — no hard sell.</p>

        <div class="contact-details-list">
          <div class="contact-detail-item">
            <span class="detail-label">EMAIL</span>
            <a href="mailto:andy@zerofluff.co.uk" class="detail-value">andy@zerofluff.co.uk</a>
          </div>
          <div class="contact-detail-item">
            <span class="detail-label">LOCATION</span>
            <span class="detail-value">Totnes, Devon, UK</span>
          </div>
          <div class="contact-detail-item">
            <span class="detail-label">HOURS</span>
            <span class="detail-value">Mon – Fri, 9am – 5pm GMT</span>
          </div>
          <div class="contact-detail-item">
            <span class="detail-label">RESPONSE TIME</span>
            <span class="detail-value">Typically within 24 hours</span>
          </div>
        </div>

        <div class="card-divider"></div>

        <p class="card-tagline">"I help small businesses save 5–15 hours a week with practical AI — not theory."</p>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .contact-hero {
    min-height: 480px;
    background: var(--color-surface);
    position: relative;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
  }

  .contact-hero-content {
    position: relative;
    z-index: 1;
    padding: 0 80px;
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-hero-content h1 {
    font-size: 56px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -1.5px;
    line-height: 1.05;
  }

  .contact-hero-content p {
    font-size: 20px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* BODY */
  .contact-body {
    background: var(--color-bg);
    padding: 80px;
  }

  .contact-body-inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 64px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: start;
  }

  /* FORM COLUMN */
  .contact-form-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .section-label {
    font-size: 12px;
    font-weight: 700;
    color: #FF3B30;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .contact-form-col h2 {
    font-size: 36px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.5px;
    line-height: 1.1;
    margin-top: -8px;
  }

  /* INFO CARD */
  .contact-info-card {
    background: var(--color-surface);
    padding: 48px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky;
    top: 100px;
  }

  .contact-info-card h3 {
    font-size: 28px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.5px;
    line-height: 1.15;
  }

  .card-desc {
    font-size: 15px;
    color: #ccc;
    line-height: 1.65;
  }

  .contact-details-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-detail-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-label {
    font-size: 11px;
    font-weight: 700;
    color: #FF3B30;
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }

  .detail-value {
    font-size: 15px;
    color: #fff;
    text-decoration: none;
  }

  a.detail-value:hover {
    color: #FF3B30;
  }

  .card-divider {
    height: 1px;
    background: #333;
    width: 100%;
  }

  .card-tagline {
    font-size: 14px;
    color: #888;
    line-height: 1.6;
    font-style: italic;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .contact-body-inner {
      grid-template-columns: 1fr;
    }
    .contact-info-card {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .contact-hero-content {
      padding: 0 24px;
    }
    .contact-hero-content h1 {
      font-size: 40px;
    }
    .contact-body {
      padding: 60px 24px;
    }
    .contact-body-inner {
      gap: 40px;
    }
    .contact-info-card {
      padding: 32px 24px;
    }
  }
</style>
