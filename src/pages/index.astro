---
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingShapes from '../components/FloatingShapes.astro';
import Starfield from '../components/Starfield.astro';
---

<BaseLayout
  title="Zero Fluff — AI Implementation That Works"
  description="Straight-talking AI consultancy for small businesses. No jargon, no fluff, just results."
>
  <Starfield />

  <!-- HERO — The Decoder -->
  <section class="hero" data-section="hero">
    <FloatingShapes />
    <canvas id="particle-canvas" aria-hidden="true"></canvas>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-content">
      <h1 data-scramble>Get AI working in your business — without the jargon</h1>
      <p class="hero-sub">We help small businesses save time and money with AI and automation. No tech overwhelm. No fluff. Just results.</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary" data-magnetic>Book a free AI chat &rarr;</a>
        <a href="/services" class="btn-outline">See our services</a>
      </div>
      <p class="trust-text">30+ years experience&nbsp;&nbsp;&bull;&nbsp;&nbsp;Based in Totnes, Devon</p>
    </div>
  </section>

  <!-- PAIN POINTS — The Domino Drop -->
  <section class="pain-section" data-section="pain">
    <div class="section-inner">
      <p class="section-label">01 — THE PROBLEM</p>
      <h2>Sound familiar?</h2>
      <div class="cards-row">
        <div class="pain-card" data-tilt>
          <div class="card-inner">
            <h3>Drowning in admin?</h3>
            <p>Repetitive tasks eating your day? Emails, invoices, scheduling — it never ends.</p>
          </div>
        </div>
        <div class="pain-card" data-tilt>
          <div class="card-inner">
            <h3>No time to figure it out?</h3>
            <p>You know AI could help, but who has time to learn another tool?</p>
          </div>
        </div>
        <div class="pain-card" data-tilt>
          <div class="card-inner">
            <h3>Confused by AI hype?</h3>
            <p>Every day there is a new AI tool. Hard to know what actually works for YOUR business.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES — The Horizontal Cinema -->
  <section class="services-section" data-section="services">
    <div class="services-track">
      <div class="services-header">
        <p class="section-label">02 — WHAT WE DO</p>
        <h2>Practical AI solutions, not buzzwords</h2>
      </div>
      <div class="services-panels">
        <div class="service-panel">
          <span class="panel-number" aria-hidden="true">01</span>
          <div class="panel-content">
            <span class="service-tag">2 HOURS</span>
            <h3>AI Quick Start</h3>
            <p>We review your business, identify where AI saves time, and give you a clear action plan.</p>
            <a href="/services" class="service-link">Learn more &rarr;</a>
          </div>
        </div>
        <div class="service-panel">
          <span class="panel-number" aria-hidden="true">02</span>
          <div class="panel-content">
            <span class="service-tag">HANDS-ON</span>
            <h3>Automation Setup</h3>
            <p>We build automated workflows using N8N, ChatGPT, Gemini and more to handle your repetitive tasks.</p>
            <a href="/services" class="service-link">Learn more &rarr;</a>
          </div>
        </div>
        <div class="service-panel">
          <span class="panel-number" aria-hidden="true">03</span>
          <div class="panel-content">
            <span class="service-tag">MONTHLY</span>
            <h3>Ongoing AI Support</h3>
            <p>Monthly support for businesses who want help staying on top of AI developments.</p>
            <a href="/services" class="service-link">Learn more &rarr;</a>
          </div>
        </div>
        <div class="service-panel">
          <span class="panel-number" aria-hidden="true">04</span>
          <div class="panel-content">
            <span class="service-tag">STRATEGIC</span>
            <h3>Bigger Projects</h3>
            <p>Building a product or need strategic tech leadership? We do that too.</p>
            <a href="/services" class="service-link">Learn more &rarr;</a>
          </div>
        </div>
      </div>
      <div class="services-progress" aria-hidden="true">
        <div class="services-progress-bar"></div>
      </div>
    </div>
    <!-- Mobile fallback -->
    <div class="services-mobile">
      <div class="services-header">
        <p class="section-label">02 — WHAT WE DO</p>
        <h2>Practical AI solutions, not buzzwords</h2>
      </div>
      <div class="services-stack">
        <div class="service-card-mobile">
          <span class="service-tag">2 HOURS</span>
          <h3>AI Quick Start</h3>
          <p>We review your business, identify where AI saves time, and give you a clear action plan.</p>
          <a href="/services" class="service-link">Learn more &rarr;</a>
        </div>
        <div class="service-card-mobile">
          <span class="service-tag">HANDS-ON</span>
          <h3>Automation Setup</h3>
          <p>We build automated workflows using N8N, ChatGPT, Gemini and more to handle your repetitive tasks.</p>
          <a href="/services" class="service-link">Learn more &rarr;</a>
        </div>
        <div class="service-card-mobile">
          <span class="service-tag">MONTHLY</span>
          <h3>Ongoing AI Support</h3>
          <p>Monthly support for businesses who want help staying on top of AI developments.</p>
          <a href="/services" class="service-link">Learn more &rarr;</a>
        </div>
        <div class="service-card-mobile">
          <span class="service-tag">STRATEGIC</span>
          <h3>Bigger Projects</h3>
          <p>Building a product or need strategic tech leadership? We do that too.</p>
          <a href="/services" class="service-link">Learn more &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT — The Slot Machine Stats -->
  <section class="about-section" data-section="about">
    <div class="about-grid-bg" aria-hidden="true"></div>
    <div class="section-inner about-inner">
      <p class="section-label">03 — WHY ZERO FLUFF</p>
      <div class="about-split">
        <div class="about-left">
          <h2>30 years of building digital products</h2>
          <p class="about-desc">Zero Fluff is a hands-on AI and automation consultancy for small businesses. Over 30 years of digital product experience. We deliver practical solutions without buzzwords.</p>
          <div class="about-tools">
            <span class="tools-label">TOOLS WE USE</span>
            <div class="tools-row">
              <span class="tool-pill" data-tool-pill>N8N</span>
              <span class="tool-pill" data-tool-pill>Zapier</span>
              <span class="tool-pill" data-tool-pill>Claude</span>
              <span class="tool-pill" data-tool-pill>ChatGPT</span>
              <span class="tool-pill" data-tool-pill>Perplexity</span>
            </div>
          </div>
          <div class="about-prev">
            <span class="tools-label">PREVIOUS WORK</span>
            <div class="clients-list">
              <span data-client>Filmily</span>
              <span data-client>SelectCommerce</span>
              <span data-client>Shiift</span>
              <span data-client>NiceGroup</span>
            </div>
          </div>
        </div>
        <div class="about-right">
          <div class="stat" data-stat="30" data-stat-suffix="+">
            <span class="stat-num">30+</span>
            <span class="stat-label">YEARS EXPERIENCE</span>
          </div>
          <div class="stat" data-stat-range="5-15">
            <span class="stat-num">5-15</span>
            <span class="stat-label">HOURS SAVED WEEKLY</span>
          </div>
          <div class="stat" data-stat-range="1-2">
            <span class="stat-num">1-2</span>
            <span class="stat-label">WEEKS TO RESULTS</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ — The AI Typewriter -->
  <section class="faq-section" data-section="faq">
    <div class="faq-inner">
      <div class="faq-left">
        <p class="section-label">04 — COMMON QUESTIONS</p>
        <h2 class="faq-heading" data-faq-heading>Got questions? We have answers.</h2>
      </div>
      <div class="faq-right">
        <details class="faq-item">
          <summary>How much time can AI really save me?</summary>
          <p data-answer="Most of our clients save 5-15 hours per week once their automations are running."></p>
        </details>
        <details class="faq-item">
          <summary>How quickly will I see results?</summary>
          <p data-answer="Most clients see meaningful results within 1-2 weeks of their first automation going live."></p>
        </details>
        <details class="faq-item">
          <summary>Do I need technical experience?</summary>
          <p data-answer="None. We handle all the technical setup. You just tell us what takes up your time."></p>
        </details>
        <details class="faq-item">
          <summary>What types of businesses do you work with?</summary>
          <p data-answer="Small businesses across all sectors — from solo consultants to teams of 20. If you have repetitive tasks, we can help."></p>
        </details>
        <details class="faq-item">
          <summary>What tools do you use?</summary>
          <p data-answer="N8N, Zapier, Claude, ChatGPT, Perplexity — whatever fits your workflow best."></p>
        </details>
      </div>
    </div>
  </section>

  <!-- FINAL CTA — The Gravity Well -->
  <section class="cta-section" data-section="cta">
    <div class="cta-bg" aria-hidden="true"></div>
    <div class="cta-content">
      <h2 class="cta-heading" data-cta-heading>Ready to get AI working for your business?</h2>
      <p class="cta-sub">Book a free 20-minute AI chat. No sales pitch. No jargon. Just an honest conversation about how AI can help.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary cta-btn cta-glow" data-magnetic data-magnetic-strength="0.5">Book a free AI chat &rarr;</a>
        <a href="mailto:andy@zerofluff.co.uk" class="btn-outline cta-btn">andy@zerofluff.co.uk</a>
      </div>
      <p class="trust-text">Free &middot; No obligation &middot; 20 minutes &middot; Plain English</p>
    </div>
  </section>
</BaseLayout>

<!-- Particle canvas — needs re-init on view transitions -->
<script is:inline data-astro-rerun>
(function() {
  const canvas = document.getElementById('particle-canvas');
  if (!canvas) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  if ('ontouchstart' in window && window.innerWidth < 769) return;

  const ctx = canvas.getContext('2d');
  let particles = [];
  let mouseX = -1000, mouseY = -1000;
  let animId;
  const PARTICLE_COUNT = 60;
  const REPEL_RADIUS = 100;

  function resize() {
    const hero = canvas.closest('.hero');
    if (!hero) return;
    canvas.width = hero.offsetWidth;
    canvas.height = hero.offsetHeight;
  }

  function createParticles() {
    particles = [];
    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        size: Math.random() * 2 + 1,
      });
    }
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const p of particles) {
      // Repel from cursor
      const dx = p.x - mouseX;
      const dy = p.y - mouseY;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < REPEL_RADIUS && dist > 0) {
        const force = (REPEL_RADIUS - dist) / REPEL_RADIUS * 0.8;
        p.vx += (dx / dist) * force;
        p.vy += (dy / dist) * force;
      }
      // Damping
      p.vx *= 0.98;
      p.vy *= 0.98;
      // Drift
      p.x += p.vx;
      p.y += p.vy;
      // Wrap
      if (p.x < 0) p.x = canvas.width;
      if (p.x > canvas.width) p.x = 0;
      if (p.y < 0) p.y = canvas.height;
      if (p.y > canvas.height) p.y = 0;
      // Draw
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';
      ctx.fill();
    }
    animId = requestAnimationFrame(animate);
  }

  const hero = canvas.closest('.hero');
  if (hero) {
    hero.addEventListener('mousemove', function(e) {
      const rect = hero.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });
    hero.addEventListener('mouseleave', function() {
      mouseX = -1000;
      mouseY = -1000;
    });
  }

  resize();
  createParticles();
  animate();
  window.addEventListener('resize', function() {
    resize();
    createParticles();
  });

  // Cleanup on navigation
  document.addEventListener('astro:before-swap', function() {
    cancelAnimationFrame(animId);
  });
})();
</script>

<!-- Main animation script -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { scrambleText } from '../scripts/text-scramble.js';
  import { initMagneticButtons } from '../scripts/magnetic-button.js';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.innerWidth < 769;

  // --- HERO ---
  // Text scramble
  const scrambleEl = document.querySelector('[data-scramble]') as HTMLElement;
  if (scrambleEl && !prefersReducedMotion) {
    scrambleText(scrambleEl, { duration: 2000, delay: 300 }).then(() => {
      const sub = document.querySelector('.hero-sub') as HTMLElement;
      if (sub) sub.classList.add('visible');
    });
  } else {
    const sub = document.querySelector('.hero-sub') as HTMLElement;
    if (sub) sub.classList.add('visible');
  }

  // Cursor glow
  if (!isMobile && !prefersReducedMotion) {
    const hero = document.querySelector('.hero') as HTMLElement;
    if (hero) {
      hero.addEventListener('mousemove', (e) => {
        const rect = hero.getBoundingClientRect();
        hero.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
        hero.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
      });
    }
  }

  // Magnetic buttons
  initMagneticButtons();

  // --- PAIN POINTS — Domino Drop ---
  if (!prefersReducedMotion) {
    const painCards = gsap.utils.toArray('.pain-card') as HTMLElement[];
    painCards.forEach((card, i) => {
      const rotation = (Math.random() - 0.5) * 10; // -5 to 5
      gsap.set(card, { y: 100, opacity: 0, rotation });
      gsap.to(card, {
        y: 0,
        opacity: 1,
        rotation: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 85%',
        },
        delay: i * 0.15,
      });
    });

    // 3D tilt on hover
    if (!isMobile) {
      document.querySelectorAll('[data-tilt]').forEach((card) => {
        const el = card as HTMLElement;
        el.addEventListener('mousemove', (e: MouseEvent) => {
          const rect = el.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width;
          const y = (e.clientY - rect.top) / rect.height;
          const rotateX = (y - 0.5) * -20; // max ±10
          const rotateY = (x - 0.5) * 20;
          el.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
        });
        el.addEventListener('mouseleave', () => {
          el.style.transition = 'transform 0.5s ease';
          el.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
          setTimeout(() => { el.style.transition = ''; }, 500);
        });
      });
    }
  }

  // --- SERVICES — Horizontal Cinema ---
  if (!prefersReducedMotion && !isMobile) {
    const track = document.querySelector('.services-track') as HTMLElement;
    const panels = document.querySelector('.services-panels') as HTMLElement;
    const progressBar = document.querySelector('.services-progress-bar') as HTMLElement;

    if (track && panels) {
      const totalWidth = panels.scrollWidth - window.innerWidth;

      gsap.to(panels, {
        x: -totalWidth,
        ease: 'none',
        scrollTrigger: {
          trigger: track,
          pin: true,
          scrub: 1,
          end: () => `+=${totalWidth}`,
          onUpdate: (self) => {
            if (progressBar) {
              progressBar.style.width = `${self.progress * 100}%`;
            }
          },
        },
      });
    }
  }

  // Mobile services stagger
  if (!prefersReducedMotion && isMobile) {
    gsap.utils.toArray('.service-card-mobile').forEach((card, i) => {
      gsap.from(card as HTMLElement, {
        y: 60,
        opacity: 0,
        duration: 0.6,
        delay: i * 0.1,
        scrollTrigger: {
          trigger: card as HTMLElement,
          start: 'top 85%',
        },
      });
    });
  }

  // --- ABOUT — Slot Machine Stats ---
  if (!prefersReducedMotion) {
    // Stat counter: "30+"
    const stat30 = document.querySelector('[data-stat="30"]');
    if (stat30) {
      const numEl = stat30.querySelector('.stat-num') as HTMLElement;
      if (numEl) {
        const counter = { val: 0 };
        gsap.to(counter, {
          val: 35,
          duration: 1.5,
          ease: 'power2.out',
          scrollTrigger: { trigger: stat30 as HTMLElement, start: 'top 80%' },
          onUpdate: () => {
            numEl.textContent = Math.round(counter.val) + '+';
          },
          onComplete: () => {
            gsap.to(counter, {
              val: 30,
              duration: 0.8,
              ease: 'elastic.out(1, 0.5)',
              onUpdate: () => {
                numEl.textContent = Math.round(counter.val) + '+';
              },
            });
          },
        });
      }
    }

    // Stat counters: range stats "5-15" and "1-2"
    document.querySelectorAll('[data-stat-range]').forEach((stat) => {
      const range = (stat as HTMLElement).dataset.statRange!;
      const [startVal, endVal] = range.split('-').map(Number);
      const numEl = stat.querySelector('.stat-num') as HTMLElement;
      if (!numEl) return;

      const counter = { a: 0, b: 0 };
      const overshootA = startVal + Math.ceil(startVal * 0.3);
      const overshootB = endVal + Math.ceil(endVal * 0.2);

      gsap.to(counter, {
        a: overshootA,
        b: overshootB,
        duration: 1.5,
        ease: 'power2.out',
        scrollTrigger: { trigger: stat as HTMLElement, start: 'top 80%' },
        onUpdate: () => {
          numEl.textContent = `${Math.round(counter.a)}-${Math.round(counter.b)}`;
        },
        onComplete: () => {
          gsap.to(counter, {
            a: startVal,
            b: endVal,
            duration: 0.8,
            ease: 'elastic.out(1, 0.5)',
            onUpdate: () => {
              numEl.textContent = `${Math.round(counter.a)}-${Math.round(counter.b)}`;
            },
          });
        },
      });
    });

    // Tool pills — stagger from random Y
    gsap.utils.toArray('[data-tool-pill]').forEach((pill, i) => {
      gsap.from(pill as HTMLElement, {
        y: 20 + Math.random() * 40,
        opacity: 0,
        duration: 0.8,
        ease: 'elastic.out(1, 0.5)',
        delay: i * 0.1,
        scrollTrigger: { trigger: '.about-tools', start: 'top 85%' },
      });
    });

    // Client names — blur reveal
    gsap.utils.toArray('[data-client]').forEach((client, i) => {
      gsap.from(client as HTMLElement, {
        filter: 'blur(10px)',
        opacity: 0,
        duration: 0.6,
        delay: i * 0.12,
        scrollTrigger: { trigger: '.about-prev', start: 'top 85%' },
      });
    });
  }

  // --- FAQ — AI Typewriter ---
  document.querySelectorAll('.faq-item').forEach((details) => {
    const p = details.querySelector('p[data-answer]') as HTMLElement;
    if (!p) return;
    const fullText = p.dataset.answer || '';
    let typing = false;
    let typingTimeout: number;

    details.addEventListener('toggle', () => {
      if ((details as HTMLDetailsElement).open) {
        if (prefersReducedMotion) {
          p.textContent = fullText;
          return;
        }
        // Start typewriter
        typing = true;
        p.textContent = '';
        p.classList.add('typing');
        let idx = 0;

        function typeChar() {
          if (!typing || idx >= fullText.length) {
            typing = false;
            p.classList.remove('typing');
            return;
          }
          p.textContent = fullText.slice(0, idx + 1) + '|';
          const char = fullText[idx];
          const pause = (char === '.' || char === ',') ? 150 : (25 + Math.random() * 20);
          idx++;
          typingTimeout = window.setTimeout(typeChar, pause);
        }
        typeChar();
      } else {
        // Close — stop typing
        typing = false;
        clearTimeout(typingTimeout);
        p.classList.remove('typing');
        p.textContent = '';
      }
    });
  });

  // FAQ heading word stagger
  if (!prefersReducedMotion) {
    const faqHeading = document.querySelector('[data-faq-heading]') as HTMLElement;
    if (faqHeading) {
      const text = faqHeading.textContent || '';
      const words = text.split(' ');
      faqHeading.innerHTML = words.map((w) => `<span class="faq-word">${w}</span>`).join(' ');
      gsap.from('.faq-word', {
        y: 40,
        opacity: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: 'power3.out',
        scrollTrigger: { trigger: faqHeading, start: 'top 80%' },
      });
    }
  }

  // --- CTA — Gravity Well ---
  if (!prefersReducedMotion) {
    const ctaHeading = document.querySelector('[data-cta-heading]') as HTMLElement;
    if (ctaHeading) {
      const text = ctaHeading.textContent || '';
      const words = text.split(' ');
      ctaHeading.innerHTML = words.map((w) => `<span class="cta-word">${w}</span>`).join(' ');

      gsap.from('.cta-word', {
        x: () => (Math.random() - 0.5) * 400,
        y: () => (Math.random() - 0.5) * 200,
        opacity: 0,
        rotation: () => (Math.random() - 0.5) * 30,
        duration: 1.2,
        stagger: 0.06,
        ease: 'elastic.out(1, 0.6)',
        scrollTrigger: { trigger: '.cta-section', start: 'top 70%' },
      });
    }

    // Sub text fade
    gsap.from('.cta-sub', {
      opacity: 0,
      y: 30,
      duration: 0.8,
      delay: 0.8,
      scrollTrigger: { trigger: '.cta-section', start: 'top 70%' },
    });
  }
</script>

<style>
  /* ========================================
     SHARED
     ======================================== */
  .section-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    border: none;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    text-decoration: none;
