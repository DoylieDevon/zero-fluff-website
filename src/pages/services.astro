---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="Services — Zero Fluff" description="Practical AI implementation services for small businesses. No jargon, no fluff.">

  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-content">
      <h1>Practical AI solutions,<br>not buzzwords</h1>
      <p>Real implementations that save you time and money, not slide decks about the future of AI.</p>
    </div>
  </section>

  <!-- SERVICES DETAIL -->
  <section class="services-detail">
    <article class="service-row">
      <div class="service-img service-img-1"></div>
      <div class="service-text">
        <span class="service-tag-label">2 HOURS</span>
        <h2>AI Quick Start</h2>
        <p>Not sure where AI can help your business? Start here. We spend 2 hours reviewing your operations, identifying the highest-value automation opportunities, and giving you a clear, prioritised action plan.</p>
        <ul>
          <li>Full business operations review</li>
          <li>3-5 specific automation recommendations</li>
          <li>Prioritised action plan with time estimates</li>
          <li>No obligation to continue</li>
        </ul>
        <a href="/contact" class="btn-red">Book a Quick Start →</a>
      </div>
    </article>

    <article class="service-row service-row-reverse">
      <div class="service-img service-img-2"></div>
      <div class="service-text">
        <span class="service-tag-label">HANDS-ON</span>
        <h2>Automation Setup</h2>
        <p>We build the automations for you using N8N, Zapier, ChatGPT, Claude and more. You describe the problem, we build the solution. Most automations are live within a week.</p>
        <ul>
          <li>Custom workflow design and build</li>
          <li>Integration with your existing tools</li>
          <li>Testing and handover documentation</li>
          <li>30-day support included</li>
        </ul>
        <a href="/contact" class="btn-red">Get a Quote →</a>
      </div>
    </article>

    <article class="service-row">
      <div class="service-img service-img-3"></div>
      <div class="service-text">
        <span class="service-tag-label">MONTHLY</span>
        <h2>Ongoing AI Support</h2>
        <p>AI is moving fast. This monthly retainer keeps you ahead — fixing what breaks, adding new automations as opportunities arise, and advising on what's worth trying.</p>
        <ul>
          <li>Monthly strategy call</li>
          <li>Unlimited small automation fixes</li>
          <li>New tool evaluations and recommendations</li>
          <li>Priority response to issues</li>
        </ul>
        <a href="/contact" class="btn-red">Learn More →</a>
      </div>
    </article>

    <article class="service-row service-row-reverse">
      <div class="service-img service-img-4"></div>
      <div class="service-text">
        <span class="service-tag-label">STRATEGIC</span>
        <h2>Bigger Projects</h2>
        <p>Building an AI-powered product, or need a fractional CTO to guide your technical strategy? 30 years of building digital products, from startup to scale.</p>
        <ul>
          <li>Product strategy and technical architecture</li>
          <li>AI/ML integration into existing products</li>
          <li>Team guidance and hiring support</li>
          <li>Flexible engagement terms</li>
        </ul>
        <a href="/contact" class="btn-red">Let's Talk →</a>
      </div>
    </article>
  </section>

  <!-- CTA -->
  <section class="services-cta">
    <div class="services-cta-content">
      <h2>Ready to get started?</h2>
      <p>Book a free 20-minute AI chat. No sales pitch.</p>
      <a href="/contact" class="btn-red cta-btn-lg">Book a free AI chat →</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    min-height: 500px;
    background: var(--color-surface);
    position: relative;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    padding: 0 80px;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .page-hero-content h1 {
    font-size: 56px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -1.5px;
    line-height: 1.05;
  }
  .page-hero-content p {
    font-size: 20px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* SERVICES DETAIL */
  .services-detail {
    padding: 0 80px;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
  }
  .service-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
    padding: 60px 0;
  }
  .service-row:first-child { padding-top: 60px; }
  .service-row-reverse .service-img { order: 2; }
  .service-row-reverse .service-text { order: 1; }
  .service-img {
    height: 400px;
  }
  .service-img-1 { background: linear-gradient(135deg, #1a0533, #0a1628); }
  .service-img-2 { background: linear-gradient(135deg, #2d1408, #1a0a0a); }
  .service-img-3 { background: linear-gradient(135deg, #081a1a, #0a1a0d); }
  .service-img-4 { background: linear-gradient(135deg, #0a1628, #1a0533); }
  .service-text {
    padding: 0 60px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    justify-content: center;
  }
  .service-tag-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #FF3B30;
    text-transform: uppercase;
  }
  .service-text h2 {
    font-size: 36px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.5px;
  }
  .service-text > p {
    font-size: 18px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .service-text ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    margin: 0;
  }
  .service-text li {
    font-size: 16px;
    color: var(--color-text-secondary);
    padding-left: 20px;
    position: relative;
  }
  .service-text li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #FF3B30;
    font-weight: 600;
  }
  .btn-red {
    display: inline-block;
    background: #FF3B30;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    text-decoration: none;
    align-self: flex-start;
    transition: opacity 0.15s;
  }
  .btn-red:hover { opacity: 0.85; color: #fff; }

  /* CTA */
  .services-cta {
    min-height: 300px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .services-cta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
    padding: 60px 80px;
  }
  .services-cta-content h2 {
    font-size: 48px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -1px;
  }
  .services-cta-content p {
    font-size: 18px;
    color: #ccc;
  }
  .cta-btn-lg {
    font-size: 18px;
    padding: 20px 48px;
  }

  @media (max-width: 768px) {
    .page-hero-content { padding: 0 24px; }
    .page-hero-content h1 { font-size: 40px; }
    .services-detail { padding: 0 24px; }
    .service-row { grid-template-columns: 1fr; padding: 40px 0; }
    .service-row-reverse .service-img { order: 0; }
    .service-row-reverse .service-text { order: 0; }
    .service-text { padding: 32px 0 0; }
    .services-cta-content { padding: 40px 24px; }
    .services-cta-content h2 { font-size: 36px; }
  }
</style>
