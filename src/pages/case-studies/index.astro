---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const studies = await getCollection('case-studies');
studies.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));

const featured = studies[0];
const rest = studies.slice(1);

const categoryColors: Record<string, string> = {
  Framework: '#FF3B30',
  Language: '#00F0FF',
  Animation: '#FF9500',
  Hosting: '#34C759',
  Email: '#AF52DE',
  Typography: '#5AC8FA',
  CMS: '#FF2D55',
  Styling: '#FFCC00',
  'Browser API': '#00F0FF',
};
---

<BaseLayout
  title="Our Work | Zero Fluff"
  description="Real results for real businesses. See how Zero Fluff has helped companies save time and make better decisions with practical AI solutions."
>
  <!-- FEATURED HERO -->
  <section class="nf-hero" id="nf-hero">
    {featured.data.image && (
      <div class="nf-hero-bg" style={`background-image:url(${featured.data.image})`} aria-hidden="true"></div>
    )}
    <div class="nf-hero-vignette" aria-hidden="true"></div>

    <div class="nf-hero-content" data-nf-hero-content>
      <div class="nf-hero-badge">
        <span class="nf-badge-dot"></span>
        FEATURED WORK
      </div>
      <h1 class="nf-hero-title" data-nf-scramble>{featured.data.client}</h1>
      <p class="nf-hero-subtitle">{featured.data.subtitle ?? featured.data.title}</p>

      {featured.data.tech && (
        <div class="nf-hero-pills">
          {featured.data.tech.slice(0, 5).map(t => (
            <span class="nf-hero-pill" style={`--c:${categoryColors[t.category] ?? '#FF3B30'}`}>{t.name}</span>
          ))}
        </div>
      )}

      <div class="nf-hero-actions">
        <a href={`/case-studies/${featured.id}`} class="nf-btn-primary" data-magnetic>
          <span class="nf-play-icon" aria-hidden="true">▶</span>
          View Case Study
        </a>
      </div>

      <p class="nf-hero-result">{featured.data.result}</p>
    </div>

    <!-- Bottom fade to black for content below -->
    <div class="nf-hero-fade" aria-hidden="true"></div>
  </section>

  <!-- WORK GRID -->
  <section class="nf-grid-section" id="nf-grid-section">
    <div class="nf-grid-header">
      <h2 class="nf-grid-title">All Work</h2>
      <p class="nf-grid-count">{studies.length} project{studies.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="nf-grid" id="nf-grid">
      {studies.map((study, i) => (
        <div
          class="nf-card"
          data-nf-card
          data-index={i}
          data-href={`/case-studies/${study.id}`}
          tabindex="0"
          role="article"
          aria-label={`${study.data.client}: ${study.data.title}`}
        >
          <div class="nf-card-img-wrap">
            {study.data.image
              ? <img src={study.data.image} alt="" class="nf-card-img" loading="lazy" />
              : <div class="nf-card-img-placeholder"></div>
            }
            <div class="nf-card-shine" aria-hidden="true"></div>
          </div>

          <div class="nf-card-info">
            <div class="nf-card-info-top">
              <span class="nf-card-client">{study.data.client}</span>
              <span class="nf-card-result-badge">{study.data.result}</span>
            </div>
            <h3 class="nf-card-name">{study.data.title}</h3>
            {study.data.subtitle && <p class="nf-card-desc">{study.data.subtitle}</p>}
            {study.data.tech && (
              <div class="nf-card-tech-row">
                {study.data.tech.slice(0, 4).map(t => (
                  <span class="nf-card-tech-tag" style={`--c:${categoryColors[t.category] ?? '#FF3B30'}`}>{t.name}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- STATS BANNER -->
  <section class="nf-stats reveal">
    <div class="nf-stats-inner">
      <div class="nf-stat">
        <span class="nf-stat-n" data-count={studies.length}>0</span>
        <span class="nf-stat-label">Case Studies</span>
      </div>
      <div class="nf-stat-divider" aria-hidden="true"></div>
      <div class="nf-stat">
        <span class="nf-stat-n">30+</span>
        <span class="nf-stat-label">Years Experience</span>
      </div>
      <div class="nf-stat-divider" aria-hidden="true"></div>
      <div class="nf-stat">
        <span class="nf-stat-n">100%</span>
        <span class="nf-stat-label">AI Powered</span>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { scrambleText } from '../../scripts/text-scramble.js';
  import { initMagneticButtons } from '../../scripts/magnetic-button.js';

  gsap.registerPlugin(ScrollTrigger);

  function initPage() {
    // Kill any leftover ScrollTriggers from previous navigation
    ScrollTrigger.getAll().forEach(t => t.kill());

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // --- HERO ENTRANCE ---
    if (!prefersReducedMotion) {
      const heroContent = document.querySelector('[data-nf-hero-content]') as HTMLElement;
      const scrambleEl = document.querySelector('[data-nf-scramble]') as HTMLElement;

      if (scrambleEl) scrambleText(scrambleEl, { duration: 1600, delay: 400 });

      if (heroContent) {
        const children = Array.from(heroContent.children) as HTMLElement[];
        gsap.from(children, {
          y: 40,
          opacity: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 0.3,
        });
      }
    }

    // --- PARALLAX HERO BG ---
    if (!prefersReducedMotion) {
      const heroBg = document.querySelector('.nf-hero-bg') as HTMLElement;
      if (heroBg) {
        gsap.to(heroBg, {
          y: '25%',
          ease: 'none',
          scrollTrigger: {
            trigger: '.nf-hero',
            start: 'top top',
            end: 'bottom top',
            scrub: true,
          },
        });
      }
    }

    // --- CHAOTIC GRID: random column spans on each load ---
    const cards = Array.from(document.querySelectorAll('[data-nf-card]')) as HTMLElement[];
    const SPAN_POOL = [4, 4, 4, 6, 6, 6, 8, 12];

    cards.forEach((card) => {
      const span = SPAN_POOL[Math.floor(Math.random() * SPAN_POOL.length)];
      card.style.gridColumn = `span ${span}`;
      card.dataset.span = String(span);
    });

    // --- CARD HOVER ---
    cards.forEach((el) => {
      el.addEventListener('mouseenter', () => el.classList.add('nf-card--hovered'));
      el.addEventListener('mouseleave', () => el.classList.remove('nf-card--hovered'));
      el.addEventListener('click', () => {
        const href = el.dataset.href;
        if (href) window.location.href = href;
      });
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const href = el.dataset.href;
          if (href) window.location.href = href;
        }
      });
    });

    // --- FLY-IN ENTRANCE ---
    if (!prefersReducedMotion && cards.length > 0) {
      gsap.set(cards, {
        y: () => -(200 + Math.random() * 800),
        x: () => (Math.random() - 0.5) * 400,
        rotation: () => (Math.random() - 0.5) * 24,
        scale: () => 0.6 + Math.random() * 0.3,
        opacity: 0,
      });

      gsap.to(cards, {
        y: 0,
        x: 0,
        rotation: 0,
        scale: 1,
        opacity: 1,
        duration: () => 0.9 + Math.random() * 0.5,
        ease: 'power4.out',
        stagger: { amount: 0.5, from: 'random' },
        delay: 0.15,
        clearProps: 'transform,opacity',
      });
    }

    // --- STATS COUNTER ---
    if (!prefersReducedMotion) {
      const countEl = document.querySelector('[data-count]') as HTMLElement;
      if (countEl) {
        const target = Number(countEl.dataset.count);
        const counter = { val: 0 };
        gsap.to(counter, {
          val: target,
          duration: 1.5,
          ease: 'power2.out',
          scrollTrigger: { trigger: '.nf-stats', start: 'top 80%' },
          onUpdate: () => { countEl.textContent = String(Math.round(counter.val)); },
        });
      }
    }

    initMagneticButtons();
  }

  // Run on every page load — covers both first load and SPA navigation
  document.addEventListener('astro:page-load', initPage);
</script>

<style>
  /* ======================================
     HERO
     ====================================== */
  .nf-hero {
    position: relative;
    height: 85vh;
    min-height: 560px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .nf-hero-bg {
    position: absolute;
    inset: -10% 0 0;
    background-size: cover;
    background-position: center 20%;
    filter: saturate(0.2) brightness(0.18) blur(3px);
    transform-origin: center top;
    animation: hero-bg-pulse 2.5s ease-in-out infinite;
  }

  @keyframes hero-bg-pulse {
    0%, 100% { filter: saturate(0.2) brightness(0.18) blur(3px); }
    50%      { filter: saturate(0.45) brightness(0.5) blur(2px); }
  }

  .nf-hero-vignette {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(5,5,5,0.95) 0%, rgba(5,5,5,0.7) 55%, rgba(5,5,5,0.4) 100%),
      linear-gradient(to bottom, rgba(5,5,5,0.3) 0%, transparent 40%),
      radial-gradient(ellipse 70% 60% at 20% 60%, rgba(255,59,48,0.15), transparent);
    z-index: 1;
    pointer-events: none;
  }

  .nf-hero-fade {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(to bottom, transparent, var(--color-bg));
    z-index: 2;
    pointer-events: none;
  }

  .nf-hero-content {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: 640px;
    padding: 0 0 80px 60px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .nf-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .nf-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: badge-pulse 1.5s ease-in-out infinite;
  }

  @keyframes badge-pulse {
    0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(255,59,48,0.4); }
    50% { opacity: 0.8; transform: scale(1.2); box-shadow: 0 0 0 6px rgba(255,59,48,0); }
  }

  .nf-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 900;
    color: var(--color-text);
    letter-spacing: -2px;
    line-height: 0.95;
    text-shadow: 0 2px 40px rgba(0,0,0,0.5);
  }

  .nf-hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.8vw, 19px);
    color: var(--color-text-secondary);
    line-height: 1.55;
    max-width: 500px;
  }

  .nf-hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .nf-hero-pill {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--c, #FF3B30);
    padding: 4px 12px;
    border: 1px solid var(--c, #FF3B30);
    border-radius: 20px;
    opacity: 0.8;
    letter-spacing: 0.5px;
  }

  .nf-hero-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .nf-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #fff;
    color: #000;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    padding: 13px 28px;
    text-decoration: none;
    border-radius: 3px;
    transition: background 0.2s, transform 0.2s;
    letter-spacing: 0.3px;
  }
  .nf-btn-primary:hover {
    background: rgba(255,255,255,0.85);
    color: #000;
    transform: scale(1.03);
  }

  .nf-play-icon {
    font-size: 13px;
  }

  .nf-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(109, 109, 110, 0.7);
    color: #fff;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    padding: 13px 28px;
    text-decoration: none;
    border-radius: 3px;
    backdrop-filter: blur(8px);
    transition: background 0.2s;
    letter-spacing: 0.3px;
  }
  .nf-btn-ghost:hover {
    background: rgba(109, 109, 110, 0.5);
    color: #fff;
  }

  .nf-hero-result {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 4px;
    opacity: 0.9;
  }

  /* ======================================
     ROWS
     ====================================== */
  /* ======================================
     GRID SECTION
     ====================================== */
  .nf-grid-section {
    background: var(--color-bg);
    padding: 60px 60px 80px;
    position: relative;
    z-index: 3;
  }

  .nf-grid-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 32px;
  }

  .nf-grid-title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.3px;
  }

  .nf-grid-count {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .nf-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-flow: row dense;
    gap: 12px;
    align-items: start;
  }

  /* ======================================
     NETFLIX CARD
     ====================================== */
  .nf-card {
    position: relative;
    border-radius: 4px;
    overflow: visible;
    cursor: pointer;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), z-index 0s 0.35s, box-shadow 0.35s ease;
    z-index: 1;
    transform-origin: center center;
    box-shadow: 0 0 0 1px rgba(255,59,48,0.25), 0 4px 24px rgba(0,0,0,0.5);
    animation: card-border-pulse 5s ease-in-out infinite;
  }

  /* Stagger the glow cycle so cards breathe out of sync */
  .nf-card:nth-child(2) { animation-delay: -1.6s; }
  .nf-card:nth-child(3) { animation-delay: -3.2s; }
  .nf-card:nth-child(4) { animation-delay: -0.8s; }
  .nf-card:nth-child(5) { animation-delay: -2.4s; }
  .nf-card:nth-child(6) { animation-delay: -4s; }

  @keyframes card-border-pulse {
    0%, 100% { box-shadow: 0 0 0 1px rgba(255,59,48,0.25), 0 4px 24px rgba(0,0,0,0.5); }
    50%       { box-shadow: 0 0 0 1px rgba(0,240,255,0.35), 0 4px 32px rgba(0,240,255,0.08); }
  }

  /* Hover — scale 10% and lift above neighbours (full-width cards just lift) */
  .nf-card--hovered {
    transform: scale(1.1);
    z-index: 20;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), z-index 0s 0s, box-shadow 0.3s ease;
    box-shadow: 0 0 0 1px rgba(0,240,255,0.5), 0 16px 48px rgba(0,0,0,0.8);
  }

  /* Full-width cards (span 12) — don't scale, just lift */
  .nf-card[style*="span 12"].nf-card--hovered {
    transform: translateY(-4px);
    box-shadow: 0 0 0 1px rgba(0,240,255,0.4), 0 12px 40px rgba(0,0,0,0.7);
  }

  .nf-card-img-wrap {
    position: relative;
    aspect-ratio: 8 / 5;
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-surface-elevated);
  }

  /* Scan line — hidden by default, only runs while hovering */
  .nf-card-img-wrap::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      rgba(0,240,255,0.0) 10%,
      rgba(0,240,255,0.9) 40%,
      rgba(0,240,255,1)   50%,
      rgba(0,240,255,0.9) 60%,
      rgba(0,240,255,0.0) 90%,
      transparent 100%
    );
    top: -2%;
    animation: none;
    z-index: 3;
    pointer-events: none;
    filter: blur(0.5px);
  }

  .nf-card--hovered .nf-card-img-wrap::after {
    animation: card-scan 2s ease-in-out infinite;
  }

  @keyframes card-scan {
    0%   { top: -2%;   opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 0.8; }
    100% { top: 102%;  opacity: 0; }
  }

  .nf-card--hovered .nf-card-img-wrap {
    border-radius: 4px 4px 0 0;
  }

  .nf-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter 0.3s;
    filter: saturate(0.8) brightness(0.85);
    display: block;
  }

  .nf-card--hovered .nf-card-img {
    filter: saturate(1) brightness(0.95);
  }

  .nf-card-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a0533 0%, #0a1628 50%, #0a1a0d 100%);
    animation: placeholder-shimmer 3s ease-in-out infinite alternate;
  }

  .nf-card-img-placeholder--ai {
    background: linear-gradient(135deg, #001a1a 0%, #0a1a2a 50%, #001a33 100%);
  }

  @keyframes placeholder-shimmer {
    0% { filter: brightness(0.8); }
    100% { filter: brightness(1.1); }
  }

  /* Shine overlay */
  .nf-card-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .nf-card--hovered .nf-card-shine {
    opacity: 1;
  }

  /* AI badge on card image */
  .nf-card-ai-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0,240,255,0.15);
    border: 1px solid rgba(0,240,255,0.4);
    border-radius: 3px;
    padding: 3px 8px;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    color: var(--color-cyan);
    letter-spacing: 2px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .nf-ai-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-cyan);
    animation: badge-pulse 1.5s ease-in-out infinite;
  }

  /* Permanent info panel below the image */
  .nf-card-info {
    padding: 14px 16px 18px;
    background: var(--color-surface);
    border-radius: 0 0 4px 4px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .nf-card-info-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .nf-card-client {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }

  .nf-card-result-badge {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 800;
    color: var(--color-text-secondary);
    letter-spacing: -0.3px;
    white-space: nowrap;
  }

  .nf-card-name {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.3px;
    line-height: 1.2;
  }

  .nf-card-desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .nf-card-tech-row {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 2px;
  }

  .nf-card-tech-tag {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    color: var(--c, #FF3B30);
    padding: 2px 8px;
    border: 1px solid var(--c, #FF3B30);
    border-radius: 10px;
    opacity: 0.8;
    letter-spacing: 0.3px;
  }

  /* ======================================
     STATS BANNER
     ====================================== */
  .nf-stats {
    padding: 60px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .nf-stats-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .nf-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }

  .nf-stat-n {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 900;
    color: var(--color-text);
    letter-spacing: -2px;
    line-height: 1;
  }

  .nf-stat-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .nf-stat-divider {
    width: 1px;
    height: 60px;
    background: var(--color-border);
    flex-shrink: 0;
    margin: 0 40px;
  }

  /* ======================================
     RESPONSIVE
     ====================================== */
  @media (max-width: 768px) {
