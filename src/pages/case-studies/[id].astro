---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies');
  return studies.map((study) => ({
    params: { id: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const categoryColors: Record<string, string> = {
  Framework: '#FF3B30',
  Language: '#00F0FF',
  Animation: '#FF9500',
  Hosting: '#34C759',
  Email: '#AF52DE',
  Typography: '#5AC8FA',
  CMS: '#FF2D55',
  Styling: '#FFCC00',
  'Browser API': '#00F0FF',
};
---

<BaseLayout
  title={`${study.data.client}: ${study.data.title} | Zero Fluff`}
  description={study.data.subtitle ?? `${study.data.client} — ${study.data.result}. See how Zero Fluff delivered real results.`}
  image={study.data.image}
>

  <!-- HERO -->
  <section class="cs-hero" id="cs-hero">
    {study.data.image && (
      <div class="cs-hero-bg" style={`background-image: url(${study.data.image})`} aria-hidden="true"></div>
    )}
    <div class="cs-hero-noise" aria-hidden="true"></div>
    <div class="cs-hero-gradient" aria-hidden="true"></div>
    <canvas id="cs-particle-canvas" aria-hidden="true"></canvas>

    <div class="cs-hero-content">
      <a href="/case-studies" class="cs-back-link" aria-label="Back to all work">
        <span class="cs-back-arrow">←</span> All work
      </a>
      <p class="cs-label" data-cs-label>CASE STUDY</p>
      <h1 class="cs-title" data-cs-scramble>{study.data.client}</h1>
      <p class="cs-subtitle" data-cs-subtitle>{study.data.subtitle ?? study.data.title}</p>

      <div class="cs-meta-row">
        <div class="cs-meta-stat">
          <span class="cs-meta-value" data-cs-result>{study.data.result}</span>
          <span class="cs-meta-key">OUTCOME</span>
        </div>
        {study.data.url && (
          <a href={study.data.url} target="_blank" rel="noopener noreferrer" class="cs-live-link" data-magnetic>
            View live site <span class="cs-link-arrow">↗</span>
          </a>
        )}
      </div>
    </div>

    <div class="cs-scroll-indicator" aria-hidden="true">
      <div class="cs-scroll-line"></div>
    </div>
  </section>

  <!-- OVERVIEW -->
  {study.data.description && (
    <section class="cs-overview reveal">
      <div class="cs-overview-inner">
        <div class="cs-overview-left">
          <p class="cs-section-label">01 — OVERVIEW</p>
          <p class="cs-description">{study.data.description}</p>
        </div>
        <div class="cs-overview-right" aria-hidden="true">
          <div class="cs-big-stat" data-cs-big-stat>
            <span class="cs-big-number">{study.data.result}</span>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- TECH STACK -->
  {study.data.tech && study.data.tech.length > 0 && (
    <section class="cs-tech reveal">
      <div class="cs-tech-inner">
        <p class="cs-section-label">02 — TOOLS & TECHNOLOGY</p>
        <h2 class="cs-section-heading">The stack that made it real</h2>

        <div class="cs-tech-grid" id="cs-tech-grid">
          {study.data.tech.map((item, i) => (
            <div
              class="cs-tech-item"
              data-cs-tech
              data-index={i}
              style={`--accent: ${categoryColors[item.category] ?? '#FF3B30'}`}
            >
              <span class="cs-tech-dot"></span>
              <span class="cs-tech-name">{item.name}</span>
              <span class="cs-tech-cat">{item.category}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Neural network SVG background -->
      <svg class="cs-neural-bg" aria-hidden="true" id="cs-neural-svg" viewBox="0 0 800 400" preserveAspectRatio="xMidYMid slice">
        <defs>
          <filter id="neural-glow">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feComposite in="SourceGraphic" in2="blur" operator="over" />
          </filter>
        </defs>
        <!-- Nodes generated by JS -->
        <g id="neural-nodes"></g>
        <g id="neural-edges"></g>
      </svg>
    </section>
  )}

  <!-- AI USED -->
  {study.data.aiUsed && study.data.aiUsed.length > 0 && (
    <section class="cs-ai reveal">
      <div class="cs-ai-inner">
        <p class="cs-section-label">03 — INTELLIGENCE</p>
        <h2 class="cs-section-heading">AI that did the building</h2>

        <div class="cs-terminal" id="cs-terminal">
          <div class="cs-terminal-header">
            <span class="cs-terminal-dot cs-terminal-dot--red"></span>
            <span class="cs-terminal-dot cs-terminal-dot--yellow"></span>
            <span class="cs-terminal-dot cs-terminal-dot--green"></span>
            <span class="cs-terminal-title">zero-fluff — ai-stack</span>
          </div>
          <div class="cs-terminal-body">
            <div class="cs-terminal-line">
              <span class="cs-terminal-prompt">$</span>
              <span class="cs-terminal-cmd" data-cs-cmd="cat ai-stack.json"> cat ai-stack.json</span>
            </div>
            <div class="cs-terminal-output" id="cs-terminal-output">
              {study.data.aiUsed.map((ai, i) => (
                <div class="cs-ai-entry" data-cs-ai-entry data-index={i}>
                  <span class="cs-ai-index">0{i + 1}</span>
                  <span class="cs-ai-name">{ai}</span>
                  <span class="cs-ai-status">ACTIVE</span>
                </div>
              ))}
            </div>
            <div class="cs-terminal-cursor" aria-hidden="true">_</div>
          </div>
          <div class="cs-terminal-scanline" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  )}

  <!-- MAIN CONTENT -->
  <section class="cs-body reveal">
    <div class="cs-body-inner">
      <p class="cs-section-label">04 — THE FULL STORY</p>
      <div class="cs-prose">
        <Content />
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  {study.data.url && (
    <section class="cs-cta-live reveal">
      <div class="cs-cta-live-bg" aria-hidden="true"></div>
      <div class="cs-cta-live-content">
        <p class="cs-section-label">SEE IT IN ACTION</p>
        <h2 class="cs-cta-live-heading">Go see the real thing</h2>
        <a href={study.data.url} target="_blank" rel="noopener noreferrer" class="cs-cta-live-btn" data-magnetic>
          {study.data.url.replace('https://', '')} ↗
        </a>
      </div>
    </section>
  )}

  <CTA
    heading="Want results like these?"
    text="Let's talk about what AI can do for your business."
    buttonText="Get in Touch"
  />

</BaseLayout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { scrambleText } from '../../scripts/text-scramble.js';
  import { initMagneticButtons } from '../../scripts/magnetic-button.js';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- HERO PARTICLES ---
  (function () {
    const canvas = document.getElementById('cs-particle-canvas') as HTMLCanvasElement | null;
    if (!canvas || prefersReducedMotion) return;
    const ctx = canvas.getContext('2d')!;
    let particles: { x: number; y: number; vx: number; vy: number; size: number; hue: number }[] = [];
    let animId: number;

    function resize() {
      const hero = canvas!.closest('.cs-hero') as HTMLElement;
      if (!hero) return;
      canvas!.width = hero.offsetWidth;
      canvas!.height = hero.offsetHeight;
    }

    function init() {
      particles = [];
      for (let i = 0; i < 50; i++) {
        particles.push({
          x: Math.random() * canvas!.width,
          y: Math.random() * canvas!.height,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          size: Math.random() * 2 + 0.5,
          hue: Math.random() > 0.5 ? 4 : 186, // red or cyan
        });
      }
    }

    function animate() {
      ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0) p.x = canvas!.width;
        if (p.x > canvas!.width) p.x = 0;
        if (p.y < 0) p.y = canvas!.height;
        if (p.y > canvas!.height) p.y = 0;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(${p.hue}, 100%, 60%, 0.4)`;
        ctx.fill();
      }
      animId = requestAnimationFrame(animate);
    }

    resize();
    init();
    animate();
    window.addEventListener('resize', () => { resize(); init(); });
    document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animId));
  })();

  // --- HERO ENTRANCE ---
  if (!prefersReducedMotion) {
    const label = document.querySelector('[data-cs-label]') as HTMLElement;
    const title = document.querySelector('[data-cs-scramble]') as HTMLElement;
    const subtitle = document.querySelector('[data-cs-subtitle]') as HTMLElement;
    const metaRow = document.querySelector('.cs-meta-row') as HTMLElement;
    const backLink = document.querySelector('.cs-back-link') as HTMLElement;

    const tl = gsap.timeline({ delay: 0.2 });

    if (backLink) tl.from(backLink, { opacity: 0, x: -20, duration: 0.5 });
    if (label) tl.from(label, { opacity: 0, y: 20, duration: 0.5 }, '-=0.2');

    if (title) {
      scrambleText(title, { duration: 1800, delay: 0 });
      tl.from(title, { opacity: 0, duration: 0.1 }, '-=0.1');
    }

    if (subtitle) tl.from(subtitle, { opacity: 0, y: 30, duration: 0.7, ease: 'power2.out' }, '+=0.5');
    if (metaRow) tl.from(metaRow, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, '-=0.3');
  }

  // --- TECH GRID SCATTER ENTRANCE ---
  if (!prefersReducedMotion) {
    const items = gsap.utils.toArray('[data-cs-tech]') as HTMLElement[];
    items.forEach((item, i) => {
      const angle = (i / items.length) * Math.PI * 2;
      const radius = 200 + Math.random() * 200;
      gsap.from(item, {
        x: Math.cos(angle) * radius,
        y: Math.sin(angle) * radius,
        opacity: 0,
        scale: 0.3,
        rotation: (Math.random() - 0.5) * 30,
        duration: 0.9,
        ease: 'elastic.out(1, 0.6)',
        delay: i * 0.05,
        scrollTrigger: { trigger: '.cs-tech', start: 'top 75%' },
      });
    });
  }

  // --- NEURAL NETWORK SVG ---
  (function () {
    const svg = document.getElementById('cs-neural-svg');
    const nodesGroup = document.getElementById('neural-nodes');
    const edgesGroup = document.getElementById('neural-edges');
    if (!svg || !nodesGroup || !edgesGroup) return;

    const NODE_COUNT = 18;
    const nodes: { x: number; y: number }[] = [];

    for (let i = 0; i < NODE_COUNT; i++) {
      nodes.push({
        x: 40 + Math.random() * 720,
        y: 40 + Math.random() * 320,
      });
    }

    // Draw edges (connect nodes within proximity)
    nodes.forEach((a, i) => {
      nodes.forEach((b, j) => {
        if (j <= i) return;
        const dist = Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2);
        if (dist < 200) {
          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('x1', String(a.x));
          line.setAttribute('y1', String(a.y));
          line.setAttribute('x2', String(b.x));
          line.setAttribute('y2', String(b.y));
          line.setAttribute('stroke', 'rgba(255,59,48,0.12)');
          line.setAttribute('stroke-width', '1');
          line.style.animation = `neural-pulse ${2 + Math.random() * 3}s ease-in-out ${Math.random() * 2}s infinite alternate`;
          edgesGroup.appendChild(line);
        }
      });
    });

    // Draw nodes
    nodes.forEach((n) => {
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', String(n.x));
      circle.setAttribute('cy', String(n.y));
      circle.setAttribute('r', String(2 + Math.random() * 3));
      circle.setAttribute('fill', Math.random() > 0.6 ? 'rgba(0,240,255,0.5)' : 'rgba(255,59,48,0.5)');
      circle.style.animation = `neural-node-pulse ${1.5 + Math.random() * 2}s ease-in-out ${Math.random() * 2}s infinite alternate`;
      nodesGroup.appendChild(circle);
    });
  })();

  // --- TERMINAL TYPEWRITER ---
  (function () {
    const terminal = document.getElementById('cs-terminal');
    if (!terminal || prefersReducedMotion) return;

    const cmd = terminal.querySelector('[data-cs-cmd]') as HTMLElement;
    const entries = terminal.querySelectorAll('[data-cs-ai-entry]') as NodeListOf<HTMLElement>;

    ScrollTrigger.create({
      trigger: terminal,
      start: 'top 75%',
      once: true,
      onEnter: () => {
        // Type the command
        if (cmd) {
          const full = cmd.dataset.csCmd ?? '';
          cmd.textContent = '';
          let i = 0;
          const interval = setInterval(() => {
            cmd.textContent = full.slice(0, i + 1);
            i++;
            if (i >= full.length) clearInterval(interval);
          }, 40);
        }

        // Stagger reveal entries
        entries.forEach((entry, i) => {
          setTimeout(() => {
            entry.classList.add('visible');
          }, 600 + i * 200);
        });
      },
    });
  })();

  // --- MAGNETIC BUTTONS ---
  initMagneticButtons();
</script>

<style>
  /* ==============================
     HERO
     ============================== */
  .cs-hero {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding-bottom: 10vh;
  }

  .cs-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    filter: saturate(0.15) blur(4px);
    transform: scale(1.05);
    animation: cs-hero-drift 20s ease-in-out infinite alternate, cs-hero-pulse 2s ease-in-out infinite;
  }

  @keyframes cs-hero-pulse {
    0%, 100% { filter: saturate(0.15) brightness(0.18) blur(4px); }
    50%      { filter: saturate(0.15) brightness(0.28) blur(4px); }
  }

  @keyframes cs-hero-drift {
    0% { transform: scale(1.05) translateY(0); }
    100% { transform: scale(1.08) translateY(-20px); }
  }

  .cs-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0.6;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .cs-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(to top, var(--color-bg) 0%, rgba(5,5,5,0.7) 50%, rgba(5,5,5,0.3) 100%),
      radial-gradient(ellipse 80% 60% at 20% 50%, rgba(255,59,48,0.15), transparent),
      radial-gradient(ellipse 60% 80% at 80% 30%, rgba(0,240,255,0.1), transparent);
    pointer-events: none;
  }

  #cs-particle-canvas {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  .cs-hero-content {
    position: relative;
    z-index: 3;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .cs-back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s;
    width: fit-content;
  }
  .cs-back-link:hover { color: var(--color-text); }
  .cs-back-arrow { font-size: 16px; }

  .cs-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .cs-title {
    font-family: var(--font-heading);
    font-size: clamp(56px, 9vw, 120px);
    font-weight: 900;
    color: var(--color-text);
    letter-spacing: -3px;
    line-height: 0.95;
    text-shadow: 0 0 80px rgba(255,59,48,0.3);
  }

  .cs-subtitle {
    font-family: var(--font-body);
    font-size: clamp(16px, 2vw, 22px);
    color: var(--color-text-secondary);
    line-height: 1.5;
    max-width: 680px;
  }

  .cs-meta-row {
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
    padding-top: 8px;
  }

  .cs-meta-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-meta-value {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -1px;
    line-height: 1;
  }

  .cs-meta-key {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .cs-live-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    padding: 14px 28px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    letter-spacing: 0.5px;
  }
  .cs-live-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(255,59,48,0.05);
  }
  .cs-link-arrow {
    font-size: 18px;
    transition: transform 0.2s;
  }
  .cs-live-link:hover .cs-link-arrow {
    transform: translate(3px, -3px);
  }

  .cs-scroll-indicator {
    position: absolute;
    bottom: 40px;
    right: 60px;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .cs-scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, var(--color-accent));
    animation: cs-scroll-grow 1.5s ease-in-out infinite;
  }

  @keyframes cs-scroll-grow {
    0% { transform: scaleY(0); transform-origin: top; opacity: 1; }
    50% { transform: scaleY(1); transform-origin: top; opacity: 1; }
    100% { transform: scaleY(1); transform-origin: bottom; opacity: 0; }
  }

  /* ==============================
     OVERVIEW
     ============================== */
  .cs-overview {
    padding: 120px 0;
  }

  .cs-overview-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    display: flex;
    gap: 80px;
    align-items: center;
  }

  .cs-overview-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .cs-description {
    font-family: var(--font-body);
    font-size: clamp(18px, 2vw, 22px);
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .cs-overview-right {
    width: 300px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-big-stat {
    text-align: center;
    padding: 40px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    position: relative;
    overflow: hidden;
  }

  .cs-big-stat::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(255,59,48,0.08), transparent);
  }

  .cs-big-number {
    font-family: var(--font-heading);
    font-size: clamp(32px, 4vw, 56px);
    font-weight: 900;
    color: var(--color-accent);
    letter-spacing: -2px;
    line-height: 1.1;
    position: relative;
  }

  /* ==============================
     SECTION LABELS / HEADINGS
     ============================== */
  .cs-section-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 4px;
    text-transform: uppercase;
  }

  .cs-section-heading {
    font-family: var(--font-heading);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -1.5px;
    line-height: 1.05;
    margin-top: 12px;
  }

  /* ==============================
     TECH STACK
     ============================== */
  .cs-tech {
    padding: 120px 0;
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
  }

  .cs-tech-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    position: relative;
    z-index: 1;
  }

  .cs-tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
    margin-top: 48px;
  }

  .cs-tech-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    background: var(--color-bg);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 6px;
    cursor: default;
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
    position: relative;
    overflow: hidden;
  }

  .cs-tech-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .cs-tech-item:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    background: rgba(255,255,255,0.03);
  }

  .cs-tech-item:hover::before {
    opacity: 1;
  }

  .cs-tech-dot {
    width: 8px;
    height: 8px;
