---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="About — Zero Fluff" description="The person behind Zero Fluff. 30+ years of digital product experience.">

  <!-- HERO -->
  <section class="page-hero">
    <div class="page-hero-content">
      <h1>The person behind<br>Zero Fluff</h1>
      <p>30 years of building digital products. Now helping small businesses get AI working for them.</p>
    </div>
  </section>

  <!-- STORY SPLIT -->
  <section class="story-section reveal">
    <div class="story-inner">
      <div class="story-text">
        <p class="section-label">01 — THE STORY</p>
        <h2>From code to consultancy</h2>
        <p>I've been building digital products since the early 90s. From startup MVPs to enterprise platforms, I've seen every trend come and go. AI is different — it's genuinely transformative for small businesses, but only if you implement it practically.</p>
        <p>Zero Fluff started because I kept seeing two things: business owners drowning in admin that AI could handle in minutes, and consultants selling expensive strategies that never got implemented. I wanted to bridge that gap.</p>
        <p>My approach is hands-on. I work with you directly, understand your actual workflows, and build solutions that stick — not slide decks that gather dust.</p>
        <div class="story-values">
          <div class="value-item">
            <span class="value-title">No jargon</span>
            <span class="value-desc">Plain English explanations, always</span>
          </div>
          <div class="value-item">
            <span class="value-title">Hands-on</span>
            <span class="value-desc">I build it with you, not for you</span>
          </div>
          <div class="value-item">
            <span class="value-title">Results first</span>
            <span class="value-desc">Measurable time savings, not theory</span>
          </div>
        </div>
      </div>
      <div class="story-portrait"></div>
    </div>
  </section>

  <!-- PHOTO STRIP -->
  <section class="photo-strip reveal">
    <div class="strip-card strip-card-1">
      <div class="strip-overlay">
        <h3>No Fluff</h3>
        <p>Direct, honest advice about what AI can and can't do for your business</p>
      </div>
    </div>
    <div class="strip-card strip-card-2">
      <div class="strip-overlay">
        <h3>Precision</h3>
        <p>Targeted solutions that solve specific problems, not generic AI advice</p>
      </div>
    </div>
    <div class="strip-card strip-card-3">
      <div class="strip-overlay">
        <h3>Results</h3>
        <p>Measurable outcomes — hours saved, costs reduced, capacity freed up</p>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar reveal">
    <div class="stats-inner">
      <div class="stat-item">
        <span class="stat-big">30+</span>
        <span class="stat-caption">YEARS EXPERIENCE</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-big">100+</span>
        <span class="stat-caption">PROJECTS DELIVERED</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-big">5-15</span>
        <span class="stat-caption">HOURS SAVED WEEKLY</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-big">1-2</span>
        <span class="stat-caption">WEEKS TO RESULTS</span>
      </div>
    </div>
  </section>

  <!-- TOOLS + PREVIOUS WORK -->
  <section class="tools-section reveal">
    <div class="tools-inner">
      <div class="tools-col">
        <span class="tools-heading">TOOLS I USE</span>
        <div class="tools-pills">
          <span class="tool-pill">N8N</span>
          <span class="tool-pill">Claude</span>
          <span class="tool-pill">ChatGPT</span>
          <span class="tool-pill">Perplexity</span>
          <span class="tool-pill">Gemini</span>
          <span class="tool-pill">Manus</span>
          <span class="tool-pill">OpenClaw</span>
        </div>
      </div>
      <div class="work-col">
        <span class="tools-heading">PREVIOUS WORK</span>
        <div class="clients-grid">
          <span>Filmily</span>
          <span>SelectCommerce</span>
          <span>Shiift</span>
          <span>NiceGroup</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="about-cta">
    <div class="about-cta-content">
      <h2>Ready to have a conversation?</h2>
      <p>Book a free 20-minute chat. No obligation, no sales pitch.</p>
      <a href="/contact" class="btn-red cta-btn-lg">Book a free AI chat →</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    min-height: 500px;
    background: var(--color-surface);
    position: relative;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
    padding: 0 80px;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .page-hero-content h1 {
    font-size: 56px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -1.5px;
    line-height: 1.05;
  }
  .page-hero-content p {
    font-size: 20px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* STORY */
  .story-section { padding: 80px 80px; background: var(--color-bg); }
  .story-inner {
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }
  .story-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .section-label {
    font-size: 12px;
    font-weight: 700;
    color: #FF3B30;
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .story-text h2 {
    font-size: 48px;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -1px;
    line-height: 1.05;
  }
  .story-text > p {
    font-size: 18px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }
  .story-values {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 8px;
  }
  .value-item {
    display: flex;
    gap: 16px;
    align-items: baseline;
  }
  .value-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text);
    min-width: 100px;
  }
  .value-desc {
    font-size: 16px;
    color: var(--color-text-muted);
  }
  .story-portrait {
    width: 480px;
    height: 580px;
    flex-shrink: 0;
    background-image: url('/images/about-portrait.png');
    background-size: cover;
    background-position: center top;
    position: relative;
  }

  /* PHOTO STRIP */
  .photo-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }
  .strip-card {
    height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .strip-card::before {
    content: '';
    position: absolute;
    inset: 0;
    mix-blend-mode: multiply;
    opacity: 0.55;
  }
  .strip-card-1 {
    background-image: url('/images/about-nofluff.png');
  }
  .strip-card-1::before { background: linear-gradient(135deg, #1a0a0a, #2d1408); }
  .strip-card-2 {
    background-image: url('/images/about-precision.png');
  }
  .strip-card-2::before { background: linear-gradient(135deg, #0a1628, #1a0533); }
  .strip-card-3 {
    background-image: url('/images/about-results.png');
  }
  .strip-card-3::before { background: linear-gradient(135deg, #081a1a, #0a1a0d); }
  .strip-overlay {
    padding: 24px 28px;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
    z-index: 1;
  }
  .strip-overlay h3 {
    font-size: 28px;
    font-weight: 700;
    color: #fff;
  }
  .strip-overlay p {
    font-size: 15px;
    color: #ccc;
    line-height: 1.4;
  }

  /* STATS BAR */
  .stats-bar {
    background: #0D0D0D;
    padding: 60px 80px;
  }
  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: space-around;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }
  .stat-big {
    font-size: 72px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -3px;
    line-height: 1;
  }
  .stat-caption {
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .stat-divider {
    width: 1px;
    height: 80px;
    background: #333;
  }

  /* TOOLS */
  .tools-section { padding: 80px 80px; background: var(--color-bg); }
  .tools-inner {
    display: flex;
    gap: 80px;
    align-items: flex-start;
  }
  .tools-col, .work-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .tools-heading {
    font-size: 12px;
    font-weight: 700;
    color: #FF3B30;
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .tools-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    max-width: 500px;
  }
  .tool-pill {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    padding: 8px 16px;
    border: 2px solid var(--color-text-muted);
    border-radius: 20px;
  }
  .clients-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .clients-grid span {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  /* CTA */
  .about-cta {
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .about-cta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
    padding: 80px;
  }
  .about-cta-content h2 {
    font-size: 48px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -1px;
  }
  .about-cta-content p {
    font-size: 18px;
    color: #ccc;
  }
  .btn-red {
    display: inline-block;
    background: #FF3B30;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    padding: 16px 32px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-red:hover { opacity: 0.85; color: #fff; }
  .cta-btn-lg {
    font-size: 18px;
    padding: 20px 48px;
  }

  @media (max-width: 768px) {
    .page-hero-content { padding: 0 24px; }
    .page-hero-content h1 { font-size: 40px; }
    .story-section { padding: 60px 24px; }
    .story-inner { flex-direction: column; }
    .story-portrait { width: 100%; height: 360px; }
    .photo-strip { grid-template-columns: 1fr; }
    .stats-bar { padding: 48px 24px; }
    .stats-inner { flex-wrap: wrap; gap: 32px; }
    .stat-divider { display: none; }
    .tools-section { padding: 60px 24px; }
    .tools-inner { flex-direction: column; gap: 40px; }
    .about-cta-content { padding: 60px 24px; }
    .about-cta-content h2 { font-size: 36px; }
  }
</style>
